<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane prefWidth="820" prefHeight="480"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="Usuarios.LoginController">

    <HBox maxHeight="480" maxWidth="820" minHeight="480" minWidth="720"
          style="-fx-background-color: #FFFFFF;
                 -fx-background-radius: 18;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 28, 0, 0, 6);">

        <!-- PANEL IZQUIERDO -->
        <StackPane maxWidth="320" minWidth="320"
                   style="-fx-background-radius: 18 0 0 18;
                          -fx-background-color: #1B5E20;">
            <ImageView fitHeight="480" fitWidth="320" opacity="0.93" preserveRatio="false">
                <image><Image url="@Images/farmacialog.jpg" /></image>
            </ImageView>
            <VBox style="-fx-background-color: linear-gradient(to bottom,
                             rgba(0,0,0,0.08) 0%,
                             rgba(27,94,32,0.55) 70%,
                             rgba(27,94,32,0.85) 100%);
                          -fx-background-radius: 18 0 0 18;" />
            <VBox alignment="BOTTOM_CENTER" style="-fx-background-radius: 18 0 0 18;">
                <padding><Insets bottom="32" left="28" right="28" /></padding>
                <Label style="-fx-font-size: 26px; -fx-font-weight: bold;
                              -fx-text-fill: #FFFFFF;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 6, 0, 0, 2);"
                       text="UsFarma" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #C8E6C9;
                              -fx-wrap-text: true; -fx-alignment: CENTER;
                              -fx-padding: 4 0 16 0;"
                       text="Sistema de Gestión Farmacéutica" />
                <HBox alignment="CENTER" spacing="7">
                    <Circle radius="3.5" style="-fx-fill: rgba(255,255,255,0.30);" />
                    <Circle radius="3.5" style="-fx-fill: rgba(255,255,255,0.80);" />
                    <Circle radius="3.5" style="-fx-fill: rgba(255,255,255,0.30);" />
                </HBox>
                <Label style="-fx-font-size: 9px;
                              -fx-text-fill: rgba(255,255,255,0.35);
                              -fx-padding: 8 0 0 0; -fx-alignment: CENTER;"
                       text="© 2025 FarmaVenta" />
            </VBox>
        </StackPane>

        <!-- PANEL DERECHO -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
            <padding><Insets bottom="44" left="52" right="52" top="52" /></padding>

            <VBox spacing="4" style="-fx-padding: 0 0 26 0;">
                <Label style="-fx-font-size: 21px; -fx-font-weight: bold;
                              -fx-text-fill: #1B5E20;" text="Bienvenido de nuevo" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;"
                       text="Inicia sesión con tus credenciales" />
            </VBox>

            <Label fx:id="lblError" managed="false" maxWidth="Infinity"
                   style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;
                          -fx-font-size: 11px; -fx-background-radius: 7;
                          -fx-border-color: #FFCDD2; -fx-border-radius: 7;
                          -fx-border-width: 1; -fx-padding: 9 13 9 13;"
                   visible="false" wrapText="true" />

            <VBox spacing="5" style="-fx-padding: 0 0 15 0;">
                <Label style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #78909C;" text="USUARIO" />
                <TextField fx:id="txtUsuario" promptText="Ingresa tu usuario"
                           style="-fx-background-color: #F5F7F8;
                                  -fx-border-color: #E0E0E0; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-padding: 12 14 12 14;
                                  -fx-font-size: 13px; -fx-text-fill: #212121;
                                  -fx-prompt-text-fill: #C0C8CC;" />
            </VBox>

            <VBox spacing="5" style="-fx-padding: 0 0 30 0;">
                <Label style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #78909C;" text="CONTRASEÑA" />
                <PasswordField fx:id="txtContrasena" promptText="••••••••"
                               style="-fx-background-color: #F5F7F8;
                                      -fx-border-color: #E0E0E0; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 12 14 12 14;
                                      -fx-font-size: 13px;
                                      -fx-prompt-text-fill: #C0C8CC;" />
            </VBox>

            <Button fx:id="btnIngresar" maxWidth="Infinity" onAction="#onLogin"
                    style="-fx-background-color: #2E7D32; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-padding: 13 0 13 0;
                           -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.40), 12, 0, 0, 4);"
                    text="Ingresar →" />
        </VBox>
    </HBox>
</StackPane>