<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Usuarios.RegistroController"
      spacing="0"
      style="-fx-background-color: #F4F6F8;">

    <!-- Encabezado -->
    <VBox style="-fx-background-color: #FFFFFF;
                 -fx-padding: 28 36 22 36;
                 -fx-border-color: transparent transparent #E0E0E0 transparent;
                 -fx-border-width: 0 0 1 0;">
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold;
                      -fx-text-fill: #1B5E20;" text="Registrar nuevo usuario" />
        <Label style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;
                      -fx-padding: 4 0 0 0;"
               text="Completa los datos para crear acceso al sistema" />
    </VBox>

    <!-- Cuerpo con scroll -->
    <ScrollPane fitToWidth="true"
                style="-fx-background-color: transparent; -fx-background: transparent;"
                VBox.vgrow="ALWAYS">
        <VBox style="-fx-padding: 32 36 32 36;" spacing="0">

            <!-- Tarjeta formulario -->
            <VBox style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);
                         -fx-padding: 32 36 32 36;"
                  spacing="0" maxWidth="620">

                <!-- Mensaje error -->
                <Label fx:id="lblError" managed="false" maxWidth="Infinity"
                       style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;
                              -fx-font-size: 11px; -fx-background-radius: 7;
                              -fx-border-color: #FFCDD2; -fx-border-radius: 7;
                              -fx-border-width: 1; -fx-padding: 9 13 9 13;"
                       visible="false" wrapText="true">
                    <VBox.margin><Insets bottom="14" /></VBox.margin>
                </Label>

                <!-- Mensaje éxito -->
                <Label fx:id="lblExito" managed="false" maxWidth="Infinity"
                       style="-fx-background-color: #E8F5E9; -fx-text-fill: #2E7D32;
                              -fx-font-size: 11px; -fx-background-radius: 7;
                              -fx-border-color: #C8E6C9; -fx-border-radius: 7;
                              -fx-border-width: 1; -fx-padding: 9 13 9 13;"
                       visible="false" wrapText="true">
                    <VBox.margin><Insets bottom="14" /></VBox.margin>
                </Label>

                <!-- Empleado -->
                <VBox spacing="5">
                    <VBox.margin><Insets bottom="14" /></VBox.margin>
                    <Label style="-fx-font-size: 10px; -fx-font-weight: bold;
                                  -fx-text-fill: #78909C;" text="EMPLEADO" />
                    <ComboBox fx:id="cmbEmpleado" maxWidth="Infinity"
                              promptText="Seleccionar empleado..."
                              style="-fx-background-color: #F5F7F8;
                                     -fx-border-color: #E0E0E0;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-padding: 4 0 4 0;" />
                </VBox>

                <!-- Fila: Usuario + Rol -->
                <HBox spacing="16">
                    <VBox.margin><Insets bottom="14" /></VBox.margin>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 10px; -fx-font-weight: bold;
                                      -fx-text-fill: #78909C;" text="USUARIO" />
                        <TextField fx:id="txtUsuario" promptText="Mínimo 4 caracteres"
                                   style="-fx-background-color: #F5F7F8;
                                          -fx-border-color: #E0E0E0; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 10 12 10 12;
                                          -fx-font-size: 12px;
                                          -fx-prompt-text-fill: #C0C8CC;" />
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 10px; -fx-font-weight: bold;
                                      -fx-text-fill: #78909C;" text="ROL" />
                        <ComboBox fx:id="cmbRol" maxWidth="Infinity"
                                  promptText="Seleccionar..."
                                  style="-fx-background-color: #F5F7F8;
                                         -fx-border-color: #E0E0E0;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-padding: 4 0 4 0;" />
                    </VBox>
                </HBox>

                <!-- Contraseña -->
                <VBox spacing="5">
                    <VBox.margin><Insets bottom="14" /></VBox.margin>
                    <Label style="-fx-font-size: 10px; -fx-font-weight: bold;
                                  -fx-text-fill: #78909C;" text="CONTRASEÑA" />
                    <PasswordField fx:id="txtContrasena" promptText="Mínimo 6 caracteres"
                                   style="-fx-background-color: #F5F7F8;
                                          -fx-border-color: #E0E0E0; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 10 12 10 12;
                                          -fx-font-size: 12px;
                                          -fx-prompt-text-fill: #C0C8CC;" />
                </VBox>

                <!-- Confirmar contraseña -->
                <VBox spacing="5">
                    <VBox.margin><Insets bottom="28" /></VBox.margin>
                    <Label style="-fx-font-size: 10px; -fx-font-weight: bold;
                                  -fx-text-fill: #78909C;" text="CONFIRMAR CONTRASEÑA" />
                    <PasswordField fx:id="txtConfirmar" promptText="Repite la contraseña"
                                   style="-fx-background-color: #F5F7F8;
                                          -fx-border-color: #E0E0E0; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 10 12 10 12;
                                          -fx-font-size: 12px;
                                          -fx-prompt-text-fill: #C0C8CC;" />
                </VBox>

                <!-- Botón registrar -->
                <Button maxWidth="320" onAction="#onRegistrar"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 8; -fx-cursor: hand;
                               -fx-padding: 13 0 13 0;
                               -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.40), 12, 0, 0, 4);"
                        text="Registrar usuario →" />
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>