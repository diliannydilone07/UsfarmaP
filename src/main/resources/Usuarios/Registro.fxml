<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="Usuarios.RegistroController"
           style="-fx-background-color: #ECEFF1;">

    <!-- TARJETA: dos columnas -->
    <HBox maxWidth="820" minWidth="720" minHeight="520" maxHeight="520"
          style="-fx-background-color: #FFFFFF;
                 -fx-background-radius: 18;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 28, 0, 0, 6);">

        <!-- ════════════════════════════════
             PANEL IZQUIERDO — Imagen completa
        ════════════════════════════════ -->
        <StackPane minWidth="320" maxWidth="320"
                   style="-fx-background-radius: 18 0 0 18;
                          -fx-background-color: #1B5E20;">

            <!-- Imagen que cubre todo el panel -->
            <ImageView fitWidth="320" fitHeight="520"
                       preserveRatio="false" opacity="0.93">
                <image><Image url="@Images/farmacialog.jpg"/></image>
            </ImageView>

            <!-- Overlay degradado -->
            <VBox style="-fx-background-color: linear-gradient(to bottom,
                             rgba(0,0,0,0.08) 0%,
                             rgba(27,94,32,0.55) 70%,
                             rgba(27,94,32,0.85) 100%);
                          -fx-background-radius: 18 0 0 18;" />

            <!-- Texto encima de la imagen -->
            <VBox alignment="BOTTOM_CENTER"
                  style="-fx-background-radius: 18 0 0 18;">
                <padding><Insets bottom="32" left="28" right="28"/></padding>

                <Label text="FarmaVenta"
                       style="-fx-font-size: 26px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #FFFFFF;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 6, 0, 0, 2);" />
                <Label text="Registro de nuevo usuario"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #C8E6C9;
                              -fx-wrap-text: true;
                              -fx-alignment: CENTER;
                              -fx-padding: 4 0 16 0;" />

                <HBox alignment="CENTER" spacing="7">
                    <Circle radius="3.5" style="-fx-fill: rgba(255,255,255,0.30);" />
                    <Circle radius="3.5" style="-fx-fill: rgba(255,255,255,0.80);" />
                    <Circle radius="3.5" style="-fx-fill: rgba(255,255,255,0.30);" />
                </HBox>
                <Label text="© 2025 FarmaVenta"
                       style="-fx-font-size: 9px;
                              -fx-text-fill: rgba(255,255,255,0.35);
                              -fx-padding: 8 0 0 0;
                              -fx-alignment: CENTER;" />
            </VBox>
        </StackPane>

        <!-- ════════════════════════════════
             PANEL DERECHO — Formulario
        ════════════════════════════════ -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
            <padding><Insets top="32" bottom="32" left="48" right="48"/></padding>

            <!-- Encabezado -->
            <VBox spacing="4" style="-fx-padding: 0 0 18 0;">
                <Label text="Crear cuenta"
                       style="-fx-font-size: 21px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1B5E20;" />
                <Label text="Completa los datos del nuevo usuario"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #9E9E9E;" />
            </VBox>

            <!-- Error -->
            <Label fx:id="lblError"
                   maxWidth="Infinity"
                   wrapText="true"
                   visible="false"
                   managed="false"
                   style="-fx-background-color: #FFEBEE;
                          -fx-text-fill: #C62828;
                          -fx-font-size: 11px;
                          -fx-background-radius: 7;
                          -fx-border-color: #FFCDD2;
                          -fx-border-radius: 7;
                          -fx-border-width: 1;
                          -fx-padding: 9 13 9 13;" />

            <!-- Éxito -->
            <Label fx:id="lblExito"
                   maxWidth="Infinity"
                   wrapText="true"
                   visible="false"
                   managed="false"
                   style="-fx-background-color: #E8F5E9;
                          -fx-text-fill: #2E7D32;
                          -fx-font-size: 11px;
                          -fx-background-radius: 7;
                          -fx-border-color: #C8E6C9;
                          -fx-border-radius: 7;
                          -fx-border-width: 1;
                          -fx-padding: 9 13 9 13;" />

            <!-- Empleado -->
            <VBox spacing="5" style="-fx-padding: 0 0 11 0;">
                <Label text="EMPLEADO"
                       style="-fx-font-size: 10px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #78909C;" />
                <ComboBox fx:id="cmbEmpleado"
                          maxWidth="Infinity"
                          promptText="Seleccionar empleado..."
                          style="-fx-background-color: #F5F7F8;
                                 -fx-border-color: #E0E0E0;
                                 -fx-border-radius: 8;
                                 -fx-background-radius: 8;" />
            </VBox>

            <!-- Fila: Usuario + Rol -->
            <HBox spacing="12" style="-fx-padding: 0 0 11 0;">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="USUARIO"
                           style="-fx-font-size: 10px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #78909C;" />
                    <TextField fx:id="txtUsuario"
                               promptText="Mín. 4 caracteres"
                               style="-fx-background-color: #F5F7F8;
                                      -fx-border-color: #E0E0E0;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 12 10 12;
                                      -fx-font-size: 12px;
                                      -fx-prompt-text-fill: #C0C8CC;" />
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="ROL"
                           style="-fx-font-size: 10px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #78909C;" />
                    <ComboBox fx:id="cmbRol"
                              maxWidth="Infinity"
                              promptText="Seleccionar..."
                              style="-fx-background-color: #F5F7F8;
                                     -fx-border-color: #E0E0E0;
                                     -fx-border-radius: 8;
                                     -fx-background-radius: 8;" />
                </VBox>
            </HBox>

            <!-- Contraseña -->
            <VBox spacing="5" style="-fx-padding: 0 0 11 0;">
                <Label text="CONTRASEÑA"
                       style="-fx-font-size: 10px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #78909C;" />
                <PasswordField fx:id="txtContrasena"
                               promptText="Mínimo 6 caracteres"
                               style="-fx-background-color: #F5F7F8;
                                      -fx-border-color: #E0E0E0;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 12 10 12;
                                      -fx-font-size: 12px;
                                      -fx-prompt-text-fill: #C0C8CC;" />
            </VBox>

            <!-- Confirmar contraseña -->
            <VBox spacing="5" style="-fx-padding: 0 0 20 0;">
                <Label text="CONFIRMAR CONTRASEÑA"
                       style="-fx-font-size: 10px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #78909C;" />
                <PasswordField fx:id="txtConfirmar"
                               promptText="Repite la contraseña"
                               style="-fx-background-color: #F5F7F8;
                                      -fx-border-color: #E0E0E0;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 12 10 12;
                                      -fx-font-size: 12px;
                                      -fx-prompt-text-fill: #C0C8CC;" />
            </VBox>

            <!-- Botón Registrar -->
            <Button text="Registrar →"
                    onAction="#onRegistrar"
                    maxWidth="Infinity"
                    style="-fx-background-color: #2E7D32;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 13px;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-padding: 13 0 13 0;
                           -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.40), 12, 0, 0, 4);" />

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="12" style="-fx-padding: 14 0 10 0;">
                <Separator HBox.hgrow="ALWAYS" />
                <Label text="o" style="-fx-text-fill: #BDBDBD; -fx-font-size: 11px;" />
                <Separator HBox.hgrow="ALWAYS" />
            </HBox>

            <!-- Volver al login -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="¿Ya tienes cuenta?"
                       style="-fx-font-size: 12px; -fx-text-fill: #78909C;" />
                <Hyperlink text="Iniciar sesión"
                           onAction="#onVolverLogin"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #2E7D32;
                                  -fx-font-weight: bold;
                                  -fx-border-color: transparent;" />
            </HBox>
        </VBox>
    </HBox>
</StackPane>
