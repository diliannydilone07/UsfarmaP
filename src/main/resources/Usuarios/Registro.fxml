<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Usuarios.RegistroController"
            style="-fx-background-color: #F0F4F1;">

    <!-- ══════════════════════════════════════════
         ENCABEZADO
         ══════════════════════════════════════════ -->
    <top>
        <VBox style="-fx-background-color: #FFFFFF;
                     -fx-border-color: #DCE8DC;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 18 28 14 28;
                     -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.07), 8, 0, 0, 2);">
            <Label text="🔐  Gestión de Usuarios"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1B5E20;" />
            <Label text="Registra nuevos usuarios o selecciona uno de la tabla para editarlo"
                   style="-fx-font-size: 12px;
                          -fx-text-fill: #78909C;" />
        </VBox>
    </top>

    <!-- ══════════════════════════════════════════
         CONTENIDO PRINCIPAL
         ══════════════════════════════════════════ -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">

            <!-- ══════════════════════════════════════════
                 PANEL IZQUIERDO: Formulario
                 ══════════════════════════════════════════ -->
            <VBox spacing="14" prefWidth="320" minWidth="300"
                  style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 12;
                         -fx-border-color: #DCE8DC;
                         -fx-border-radius: 12;
                         -fx-border-width: 1;
                         -fx-padding: 22;
                         -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.06), 8, 0, 0, 2);">

                <!-- Título panel -->
                <Label text="Datos del usuario"
                       style="-fx-font-size: 14px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1B5E20;" />

                <!-- Separador -->
                <Separator style="-fx-background-color: #E8F5E9;" />

                <!-- Empleado -->
                <VBox spacing="4">
                    <Label text="Empleado"
                           style="-fx-font-size: 12px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #455A64;" />
                    <ComboBox fx:id="cmbEmpleado"
                              maxWidth="Infinity"
                              promptText="Selecciona un empleado..."
                              style="-fx-background-radius: 8;
                                     -fx-border-color: #C8D8C8;
                                     -fx-border-radius: 8;
                                     -fx-font-size: 12px;" />
                    <Label text="Solo se listan empleados sin credencial"
                           style="-fx-font-size: 10px;
                                  -fx-text-fill: #90A4AE;" />
                </VBox>

                <!-- Usuario -->
                <VBox spacing="4">
                    <Label text="Nombre de usuario"
                           style="-fx-font-size: 12px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #455A64;" />
                    <TextField fx:id="txtUsuario"
                               promptText="Mínimo 4 caracteres"
                               style="-fx-background-radius: 8;
                                      -fx-border-color: #C8D8C8;
                                      -fx-border-radius: 8;
                                      -fx-font-size: 12px;
                                      -fx-padding: 8;" />
                </VBox>

                <!-- Contraseña -->
                <VBox spacing="4">
                    <Label text="Contraseña"
                           style="-fx-font-size: 12px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #455A64;" />
                    <PasswordField fx:id="txtContrasena"
                                   promptText="Mínimo 6 caracteres"
                                   style="-fx-background-radius: 8;
                                          -fx-border-color: #C8D8C8;
                                          -fx-border-radius: 8;
                                          -fx-font-size: 12px;
                                          -fx-padding: 8;" />
                </VBox>

                <!-- Confirmar contraseña -->
                <VBox spacing="4">
                    <Label text="Confirmar contraseña"
                           style="-fx-font-size: 12px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #455A64;" />
                    <PasswordField fx:id="txtConfirmar"
                                   promptText="Repite la contraseña"
                                   style="-fx-background-radius: 8;
                                          -fx-border-color: #C8D8C8;
                                          -fx-border-radius: 8;
                                          -fx-font-size: 12px;
                                          -fx-padding: 8;" />
                    <Label text="En edición: déjala en blanco para no cambiarla"
                           style="-fx-font-size: 10px;
                                  -fx-text-fill: #90A4AE;" />
                </VBox>

                <!-- Rol -->
                <VBox spacing="4">
                    <Label text="Rol"
                           style="-fx-font-size: 12px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #455A64;" />
                    <ComboBox fx:id="cmbRol"
                              maxWidth="Infinity"
                              promptText="Selecciona un rol..."
                              style="-fx-background-radius: 8;
                                     -fx-border-color: #C8D8C8;
                                     -fx-border-radius: 8;
                                     -fx-font-size: 12px;" />
                </VBox>

                <!-- Mensajes -->
                <Label fx:id="lblError"
                       wrapText="true"
                       visible="false"
                       managed="false"
                       style="-fx-text-fill: #C62828;
                              -fx-font-size: 12px;
                              -fx-background-color: #FFEBEE;
                              -fx-background-radius: 7;
                              -fx-padding: 8;" />

                <Label fx:id="lblExito"
                       wrapText="true"
                       visible="false"
                       managed="false"
                       style="-fx-text-fill: #2E7D32;
                              -fx-font-size: 12px;
                              -fx-background-color: #E8F5E9;
                              -fx-background-radius: 7;
                              -fx-padding: 8;" />

                <Region VBox.vgrow="ALWAYS" />

                <!-- ── Botones de acción ── -->
                <HBox spacing="10">

                    <!-- BOTÓN PRINCIPAL: texto cambia entre "Registrar" y "Actualizar" -->
                    <Button fx:id="btnAccion"
                            text="Registrar"
                            onAction="#onRegistrar"
                            maxWidth="Infinity"
                            HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #1B5E20;
                                   -fx-text-fill: #FFFFFF;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 9;
                                   -fx-cursor: hand;
                                   -fx-padding: 10 0 10 0;" />

                    <!-- Limpiar / Cancelar -->
                    <Button text="✕  Limpiar"
                            onAction="#onLimpiar"
                            style="-fx-background-color: #ECEFF1;
                                   -fx-text-fill: #455A64;
                                   -fx-font-size: 13px;
                                   -fx-background-radius: 9;
                                   -fx-cursor: hand;
                                   -fx-padding: 10 16 10 16;" />
                </HBox>

            </VBox>
            <!-- ══ FIN FORMULARIO ══ -->


            <!-- ══════════════════════════════════════════
                 PANEL DERECHO: Tabla de usuarios
                 ══════════════════════════════════════════ -->
            <VBox spacing="12" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 12;
                         -fx-border-color: #DCE8DC;
                         -fx-border-radius: 12;
                         -fx-border-width: 1;
                         -fx-padding: 22;
                         -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.06), 8, 0, 0, 2);">

                <!-- Cabecera del panel tabla -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Usuarios registrados"
                               style="-fx-font-size: 14px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1B5E20;" />
                        <Label text="Haz clic en una fila para cargar los datos en el formulario"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #90A4AE;" />
                    </VBox>

                    <!-- Buscador -->
                    <TextField fx:id="txtBuscarUsuario"
                               promptText="🔍  Buscar usuario..."
                               prefWidth="220"
                               style="-fx-background-radius: 20;
                                      -fx-border-color: #C8D8C8;
                                      -fx-border-radius: 20;
                                      -fx-font-size: 12px;
                                      -fx-padding: 7 14 7 14;" />
                </HBox>

                <Separator style="-fx-background-color: #E8F5E9;" />

                <!-- Tabla -->
                <TableView fx:id="tablaUsuarios"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-radius: 8;
                                  -fx-border-color: #E0EBE0;
                                  -fx-border-radius: 8;">

                    <columns>
                        <TableColumn fx:id="colId"      text="ID"       prefWidth="50"  />
                        <TableColumn fx:id="colNombre"   text="Empleado" prefWidth="200" />
                        <TableColumn fx:id="colUsuario"  text="Usuario"  prefWidth="140" />
                        <TableColumn fx:id="colRol"      text="Rol"      prefWidth="120" />
                        <TableColumn fx:id="colEstado"   text="Estado"   prefWidth="90"  />
                        <TableColumn fx:id="colAcceso"   text="Último acceso" prefWidth="145" />
                    </columns>

                    <placeholder>
                        <Label text="Sin usuarios registrados"
                               style="-fx-text-fill: #90A4AE; -fx-font-size: 13px;" />
                    </placeholder>
                </TableView>

                <!-- Botones inferiores de la tabla -->
                <HBox spacing="10" alignment="CENTER_RIGHT">

                    <Button text="🔄  Activar / Desactivar"
                            onAction="#onToggleEstado"
                            style="-fx-background-color: #E3F2FD;
                                   -fx-text-fill: #1565C0;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;
                                   -fx-border-color: #BBDEFB;
                                   -fx-border-radius: 8;
                                   -fx-border-width: 1;
                                   -fx-cursor: hand;
                                   -fx-padding: 8 16 8 16;" />

                    <Button text="🗑  Eliminar"
                            onAction="#onEliminar"
                            style="-fx-background-color: #FFEBEE;
                                   -fx-text-fill: #C62828;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;
                                   -fx-border-color: #FFCDD2;
                                   -fx-border-radius: 8;
                                   -fx-border-width: 1;
                                   -fx-cursor: hand;
                                   -fx-padding: 8 16 8 16;" />
                </HBox>

            </VBox>
            <!-- ══ FIN TABLA ══ -->

        </HBox>
    </center>

</BorderPane>
