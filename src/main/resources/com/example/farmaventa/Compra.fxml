<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: #F4F6F8; -fx-background: #F4F6F8;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.farmaventa.CompraController">

    <VBox spacing="0" style="-fx-background-color: #F4F6F8;">

        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
            <padding><Insets bottom="18" left="24" right="24" top="18"/></padding>
            <VBox spacing="2">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="Registro de Compra"/>
                <Label style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;" text="Gestiona las compras a proveedores y actualiza el inventario"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label style="-fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-background-color: #E8F5E9; -fx-background-radius: 20; -fx-padding: 4 12 4 12;" text="Nueva compra"/>
        </HBox>

        <VBox spacing="16">
            <padding><Insets bottom="24" left="20" right="20" top="20"/></padding>

            <HBox spacing="16" minHeight="480">

                <!-- Columna izquierda: formulario -->
                <VBox prefWidth="290" spacing="12"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
                    <padding><Insets bottom="20" left="18" right="18" top="20"/></padding>

                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Datos de la Compra"/>
                    <Separator/>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Compra (buscar existente)"/>
                        <HBox spacing="8">
                            <TextField fx:id="txtIdCompra" promptText="Ej. 3" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" HBox.hgrow="ALWAYS"/>
                            <Button onAction="#onBuscarCompra" style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 10 4 10;" text="Buscar"/>
                        </HBox>
                        <Label fx:id="lblInfoCompra" style="-fx-font-size: 11px; -fx-text-fill: #2E7D32;" text="" wrapText="true"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Proveedor *"/>
                        <TextField fx:id="txtIdProveedor" promptText="Ej. 1" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Empleado"/>
                        <TextField fx:id="txtIdEmpleado" promptText="Ej. 1" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Tipo de Compra"/>
                        <ComboBox fx:id="cmbTipoCompra" maxWidth="Infinity" promptText="Seleccionar..." style="-fx-background-radius: 6;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Fecha"/>
                        <DatePicker fx:id="dpFechaCompra" maxWidth="Infinity" style="-fx-background-radius: 6;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Condicion de pago"/>
                        <TextField fx:id="txtCondicion" promptText="Contado / Credito" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Monto Pagado Inicial (RD$)"/>
                        <TextField fx:id="txtMontoPagado" promptText="0.00" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>
                    <Separator/>

                    <HBox spacing="10">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #9E9E9E; -fx-font-weight: bold;" text="MONTO TOTAL"/>
                            <Label fx:id="lblMontoTotal" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="RD$ 0.00"/>
                        </VBox>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #9E9E9E; -fx-font-weight: bold;" text="PENDIENTE"/>
                            <Label fx:id="lblMontoPendiente" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #C62828;" text="RD$ 0.00"/>
                        </VBox>
                    </HBox>

                    <Separator/>

                    <HBox spacing="8">
                        <Button maxWidth="Infinity" onAction="#onRegistrarCompra"
                                style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10 0 10 0;"
                                text="Registrar Compra" HBox.hgrow="ALWAYS"/>
                        <Button onAction="#Limpiar"
                                style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10 14 10 14;"
                                text="Limpiar"/>
                    </HBox>
                </VBox>

                <!-- Columna derecha: agregar producto + tabla -->
                <VBox spacing="12" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
                    <padding><Insets bottom="16" left="18" right="18" top="18"/></padding>

                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Productos en esta Compra"/>
                    <Separator/>

                    <!-- Seccion para agregar producto con campos de texto -->
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-background-color: #F9FBF9; -fx-background-radius: 8; -fx-border-color: #C8E6C9; -fx-border-radius: 8; -fx-border-width: 1;">
                        <padding><Insets bottom="10" left="12" right="12" top="10"/></padding>

                        <VBox spacing="3" prefWidth="90">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="ID Producto"/>
                            <TextField fx:id="txtIdProducto" promptText="Ej. 5" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                        </VBox>

                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="Nombre del Producto"/>
                            <TextField fx:id="txtNombreProducto" editable="false" promptText="Se llena al buscar"
                                       style="-fx-background-color: #F5F5F5; -fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                        </VBox>

                        <VBox spacing="3" prefWidth="70">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="Cantidad"/>
                            <TextField fx:id="txtCantidadProducto" promptText="1" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                        </VBox>

                        <VBox spacing="3" prefWidth="90">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="Precio (RD$)"/>
                            <TextField fx:id="txtPrecioProducto" promptText="0.00" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                        </VBox>

                        <VBox spacing="3" alignment="BOTTOM_LEFT">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: transparent;" text="x"/>
                            <Button onAction="#onBuscarProductoId"
                                    style="-fx-background-color: #E8F5E9; -fx-text-fill: #1B5E20; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 10 6 10;"
                                    text="Buscar"/>
                        </VBox>

                        <VBox spacing="3" alignment="BOTTOM_LEFT">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: transparent;" text="x"/>
                            <Button onAction="#onAgregarProducto"
                                    style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 10 6 10;"
                                    text="Agregar"/>
                        </VBox>
                    </HBox>

                    <!-- Buscador en tabla -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtBuscarProducto" prefWidth="220" promptText="Buscar en la tabla..."
                                   style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                        <Button onAction="#fnBuscarProducto"
                                style="-fx-background-color: #F5F5F5; -fx-text-fill: #424242; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 5 10 5 10;"
                                text="Buscar"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblCantProductos" style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;" text="0 productos"/>
                    </HBox>

                    <TableView fx:id="tablaCompraProducto" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colCompraId"         prefWidth="80"  text="Compra #"/>
                            <TableColumn fx:id="colProveedor"        prefWidth="140" text="Proveedor"/>
                            <TableColumn fx:id="colProductoNombre"   prefWidth="180" text="Producto"/>
                            <TableColumn fx:id="colProductoCantidad" prefWidth="80"  text="Cantidad"/>
                            <TableColumn fx:id="colProductoPrecio"   prefWidth="110" text="Precio Unit."/>
                            <TableColumn fx:id="colProductoSubtotal" prefWidth="110" text="Subtotal"/>
                        </columns>
                        <placeholder>
                            <Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;" text="Aun no has agregado productos"/>
                        </placeholder>
                    </TableView>

                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button onAction="#onEditarCompra"
                                style="-fx-background-color: #E3F2FD; -fx-text-fill: #1565C0; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 6; -fx-border-color: #BBDEFB; -fx-cursor: hand; -fx-padding: 8 14 8 14;"
                                text="Editar Compra"/>
                        <Button onAction="#onQuitarProducto"
                                style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828; -fx-border-color: #FFCDD2; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 14 8 14;"
                                text="Quitar Producto"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- Seccion de Pagos -->
            <VBox spacing="16"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
                <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2E7D32;" text="Pagos de la Compra"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblResumenPago" text="" style="-fx-font-size: 12px; -fx-text-fill: #757575;" wrapText="false"/>
                </HBox>
                <Separator/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Compra *"/>
                        <TextField fx:id="txtIdCompraPago" promptText="Se llena al buscar" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Metodo de Pago *"/>
                        <ComboBox fx:id="cmbMetodoPago" maxWidth="Infinity" promptText="Seleccionar..." style="-fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Cuenta Bancaria *"/>
                        <ComboBox fx:id="cmbCuenta" maxWidth="Infinity" promptText="Banco - Cuenta..." style="-fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="4" prefWidth="150">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Fecha de Pago"/>
                        <DatePicker fx:id="dpFechaPago" maxWidth="Infinity" style="-fx-background-radius: 6;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Monto a Pagar (RD$) *"/>
                        <TextField fx:id="txtMontoPago" promptText="0.00" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                    </VBox>
                    <VBox spacing="4" alignment="BOTTOM_CENTER" prefWidth="160">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: transparent;" text="."/>
                        <Button maxWidth="Infinity" onAction="#onRegistrarPago"
                                style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 7 0 7 0;"
                                text="Registrar Pago"/>
                    </VBox>
                </HBox>

                <Separator/>

                <TableView fx:id="tablaPagos" prefHeight="180" style="-fx-background-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colPagoId"     prefWidth="70"  text="#"/>
                        <TableColumn fx:id="colPagoFecha"  prefWidth="120" text="Fecha"/>
                        <TableColumn fx:id="colPagoMonto"  prefWidth="140" text="Monto (RD$)"/>
                        <TableColumn fx:id="colPagoMetodo" prefWidth="140" text="Metodo"/>
                        <TableColumn fx:id="colPagoCuenta" prefWidth="220" text="Cuenta / Banco"/>
                        <TableColumn fx:id="colPagoEstado" prefWidth="120" text="Estado"/>
                    </columns>
                    <placeholder>
                        <Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;" text="No hay pagos registrados para esta compra"/>
                    </placeholder>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <Button onAction="#onEliminarPago"
                            style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828; -fx-border-color: #FFCDD2; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16 8 16;"
                            text="Eliminar Pago Seleccionado"/>
                </HBox>
            </VBox>

        </VBox>
    </VBox>
</ScrollPane>
