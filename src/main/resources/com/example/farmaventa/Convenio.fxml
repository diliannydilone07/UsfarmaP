<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="Infinity" spacing="0" style="-fx-background-color: #F0F4F1;" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.farmaventa.ConvenioController">

    <!-- ══ ENCABEZADO ══ -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #FFFFFF;                  -fx-border-color: #DCE8DC; -fx-border-width: 0 0 1 0;                  -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.07), 8, 0, 0, 2);">
        <padding><Insets bottom="18" left="24" right="24" top="18" /></padding>
        <VBox spacing="2">
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="Gestión de Convenios" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #78909C;" text="Registra y administra los convenios con proveedores" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblVigencia" style="-fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-weight: bold;                       -fx-background-color: #E8F5E9; -fx-background-radius: 20;                       -fx-padding: 4 12 4 12;" text="● Vigente" />
    </HBox>

    <!-- ══ CUERPO ══ -->
    <HBox minHeight="580" spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

        <!-- ── COLUMNA IZQUIERDA: Formulario ── -->
        <VBox prefWidth="320" spacing="14" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;                      -fx-border-color: #DCE8DC; -fx-border-radius: 12; -fx-border-width: 1;                      -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.06), 8, 0, 0, 2);">
            <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

            <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1B5E20;" text="Datos del Convenio" />
            <Separator style="-fx-background-color: #E8F5E9;" />

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #455A64;" text="ID Proveedor *" />
                <TextField fx:id="txtIdProveedor" promptText="Ej. 1" style="-fx-background-radius: 8; -fx-border-color: #C8D8C8;                                   -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 8;" />
            </VBox>

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #455A64;" text="ID Producto *" />
                <TextField fx:id="txtIdProducto" promptText="Ej. 5" style="-fx-background-radius: 8; -fx-border-color: #C8D8C8;                                   -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 8;" />
            </VBox>

            <HBox spacing="10">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #455A64;" text="Fecha Inicio *" />
                    <DatePicker fx:id="dpFechaInicio" maxWidth="Infinity" style="-fx-background-radius: 8; -fx-border-color: #C8D8C8; -fx-border-radius: 8;" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #455A64;" text="Fecha Fin *" />
                    <DatePicker fx:id="dpFechaFin" maxWidth="Infinity" style="-fx-background-radius: 8; -fx-border-color: #C8D8C8; -fx-border-radius: 8;" />
                </VBox>
            </HBox>

            <VBox spacing="4" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #455A64;" text="Acuerdo / Descripción *" />
                <TextArea fx:id="taAcuerdo" prefRowCount="6" promptText="Detalla los términos del convenio..." style="-fx-background-radius: 8; -fx-border-color: #C8D8C8;                                  -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 8;" wrapText="true" VBox.vgrow="ALWAYS" />
            </VBox>

            <Separator style="-fx-background-color: #E8F5E9;" />

            <!-- Botones principales dentro del formulario -->
            <HBox spacing="8">
                <Button fx:id="btnGuardarConvenio" maxWidth="Infinity" onAction="#onGuardarConvenio" style="-fx-background-color: #1B5E20; -fx-text-fill: #FFFFFF;                                -fx-font-size: 13px; -fx-font-weight: bold;                                -fx-background-radius: 9; -fx-border-color: #145214;                                -fx-border-radius: 9; -fx-border-width: 1;                                -fx-cursor: hand; -fx-padding: 10 18 10 18;" text="💾 Guardar" HBox.hgrow="ALWAYS" />
                <Button onAction="#limpiar" prefHeight="40.0" prefWidth="113.0" style="-fx-background-color: #ECEFF1; -fx-text-fill: #455A64;                                -fx-font-size: 12px; -fx-background-radius: 9;                                -fx-border-color: #CFD8DC; -fx-border-radius: 9;                                -fx-border-width: 1; -fx-cursor: hand;                                -fx-padding: 10 16 10 16;" text="✕ Limpiar" />
            </HBox>
        </VBox>

        <!-- ── COLUMNA DERECHA: Tabla + Acciones ── -->
        <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;                      -fx-border-color: #DCE8DC; -fx-border-radius: 12; -fx-border-width: 1;                      -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.06), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

            <!-- Cabecera tabla -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1B5E20;" text="Convenios Registrados" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #90A4AE;" text="Selecciona uno para editarlo o eliminarlo" />
                </VBox>
                <TextField fx:id="txtBuscar" prefWidth="230" promptText="🔍  Buscar proveedor / producto..." style="-fx-background-radius: 20; -fx-border-radius: 20;                                   -fx-border-color: #C8D8C8; -fx-border-width: 1;                                   -fx-padding: 7 14 7 14;" />
            </HBox>
            <Separator style="-fx-background-color: #E8F5E9;" />

            <TableView fx:id="tablaConvenios" style="-fx-background-color: transparent; -fx-border-color: #E8F0E8; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="55" text="#" />
                    <TableColumn fx:id="colProveedor" prefWidth="170" text="Proveedor" />
                    <TableColumn fx:id="colProducto" prefWidth="170" text="Producto" />
                    <TableColumn fx:id="colFechaInicio" prefWidth="100" text="Inicio" />
                    <TableColumn fx:id="colFechaFin" prefWidth="100" text="Fin" />
                    <TableColumn fx:id="colVigencia" prefWidth="100" text="Estado" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #90A4AE; -fx-font-size: 13px;" text="No hay convenios registrados aún 📋" />
                </placeholder>
            </TableView>

            <!-- Acciones de tabla -->
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button fx:id="btnEditarConvenio" maxWidth="Infinity" onAction="#onEditarConvenio" style="-fx-background-color: #E3F2FD; -fx-text-fill: #1565C0;                                -fx-font-size: 12px; -fx-font-weight: bold;                                -fx-background-radius: 8; -fx-border-color: #BBDEFB;                                -fx-border-radius: 8; -fx-border-width: 1;                                -fx-cursor: hand; -fx-padding: 8 16 8 16;" text="✏ Editar Seleccionado" />
                <Button fx:id="btnEliminarConvenio" onAction="#onEliminarConvenio" style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;                                -fx-font-size: 12px; -fx-font-weight: bold;                                -fx-background-radius: 8; -fx-border-color: #FFCDD2;                                -fx-border-radius: 8; -fx-border-width: 1;                                -fx-cursor: hand; -fx-padding: 8 16 8 16;" text="🗑 Eliminar" />
            </HBox>
        </VBox>
    </HBox>
</VBox>
