<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox minHeight="650" spacing="0" style="-fx-background-color: #F4F6F8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.farmaventa.ConvenioController">

    <!-- ══════  ENCABEZADO  ══════ -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #FFFFFF;                  -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <padding><Insets bottom="18" left="24" right="24" top="18" /></padding>
        <VBox spacing="2">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="Gestión de Convenios" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;" text="Registra y administra los convenios con proveedores" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblVigencia" style="-fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-weight: bold;                       -fx-background-color: #E8F5E9; -fx-background-radius: 20;                       -fx-padding: 4 12 4 12;" text="● Vigente" />
    </HBox>

    <!-- ══════  CUERPO  ══════ -->
    <HBox minHeight="580" spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

        <!-- ─────  COLUMNA IZQUIERDA: Formulario  ───── -->
        <VBox prefWidth="280" spacing="14" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);                      -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

            <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Datos del Convenio" />
            <Separator />

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Proveedor *" />
                <TextField fx:id="txtIdProveedor" promptText="Ej. 1" style="-fx-background-radius: 6; -fx-border-radius: 6;                                   -fx-border-color: #E0E0E0; -fx-border-width: 1;" />
            </VBox>

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Producto *" />
                <TextField fx:id="txtIdProducto" promptText="Ej. 5" style="-fx-background-radius: 6; -fx-border-radius: 6;                                   -fx-border-color: #E0E0E0; -fx-border-width: 1;" />
            </VBox>

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Fecha Inicio *" />
                <DatePicker fx:id="dpFechaInicio" maxWidth="Infinity" style="-fx-background-radius: 6;" />
            </VBox>

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Fecha Fin *" />
                <DatePicker fx:id="dpFechaFin" maxWidth="Infinity" style="-fx-background-radius: 6;" />
            </VBox>

            <VBox spacing="4" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Acuerdo / Descripción *" />
                <TextArea fx:id="taAcuerdo" prefRowCount="5" promptText="Detalla los términos del convenio..." style="-fx-background-radius: 6; -fx-border-radius: 6;                                  -fx-border-color: #E0E0E0; -fx-border-width: 1;" wrapText="true" />
            </VBox>

        </VBox>

        <!-- ─────  COLUMNA CENTRAL: Tabla  ───── -->
        <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);                      -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
            <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Convenios Registrados" />
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtBuscar" prefWidth="240" promptText="🔍  Buscar proveedor / producto..." style="-fx-background-radius: 20; -fx-border-radius: 20;                                   -fx-border-color: #E0E0E0; -fx-border-width: 1;                                   -fx-padding: 5 12 5 12;" />
            </HBox>
            <Separator />

            <TableView fx:id="tablaConvenios" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="55" text="#" />
                    <TableColumn fx:id="colProveedor" prefWidth="160" text="Proveedor" />
                    <TableColumn fx:id="colProducto" prefWidth="160" text="Producto" />
                    <TableColumn fx:id="colFechaInicio" prefWidth="100" text="Inicio" />
                    <TableColumn fx:id="colFechaFin" prefWidth="100" text="Fin" />
                    <TableColumn fx:id="colVigencia" prefWidth="90" text="Estado" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;" text="No hay convenios registrados aún 📋" />
                </placeholder>
            </TableView>

        </VBox>

        <!-- ─────  COLUMNA DERECHA: Acciones  ───── -->
        <VBox prefWidth="230" spacing="10">

            <VBox spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);                          -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
                <padding><Insets bottom="16" left="14" right="14" top="16" /></padding>
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #424242;" text="Acciones" />
                <Separator />

                <!-- Solo inserta nuevo -->
                <Button maxWidth="Infinity" onAction="#onGuardarConvenio" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                -fx-font-weight: bold; -fx-font-size: 11px;                                -fx-background-radius: 6; -fx-cursor: hand;                                -fx-padding: 10 6 10 6;" text="✔ Guardar Nuevo" />

                <!-- Solo actualiza el seleccionado -->
                <Button maxWidth="Infinity" onAction="#onEditarConvenio" style="-fx-background-color: #E3F2FD; -fx-text-fill: #1565C0;                                -fx-font-weight: bold; -fx-font-size: 11px;                                -fx-background-radius: 6; -fx-border-color: #BBDEFB;                                -fx-cursor: hand; -fx-padding: 10 6 10 6;" text="✏ Editar Convenio" />

                <Button maxWidth="Infinity" onAction="#onEliminarConvenio" style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;                                -fx-font-size: 11px; -fx-background-radius: 6;                                -fx-border-color: #FFCDD2; -fx-cursor: hand;                                -fx-padding: 9 6 9 6;" text="🗑 Eliminar Convenio" />

                <Button maxWidth="Infinity" onAction="#limpiar" style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;                                -fx-font-size: 11px; -fx-background-radius: 6;                                -fx-cursor: hand; -fx-padding: 9 6 9 6;" text="🔄 Limpiar" />
            </VBox>

        </VBox>
    </HBox>
</VBox>
