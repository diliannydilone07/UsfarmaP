<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<VBox maxHeight="Infinity" spacing="0" style="-fx-background-color: #F0F4F1;" VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.farmaventa.controlador.DashboardController">

    <VBox prefHeight="110" spacing="0"
          style="-fx-background-color: linear-gradient(to right, #1B5E20, #2E7D32, #388E3C);
                 -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.25), 12, 0, 0, 4);
                 -fx-padding: 24 28 18 28;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label fx:id="lblBienvenida"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;" text="Bienvenido"/>
                <HBox spacing="10">
                    <Label fx:id="lblRol"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #A5D6A7;
                                  -fx-background-color: rgba(255,255,255,0.12); -fx-background-radius: 12;
                                  -fx-padding: 2 10 2 10;" text="ROL"/>
                    <Label fx:id="lblFecha"
                           style="-fx-font-size: 12px; -fx-text-fill: #C8E6C9;" text=""/>
                </HBox>
            </VBox>
            <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #C8E6C9;
                          -fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 12;
                          -fx-padding: 4 14 4 14;" text="Panel de Control"/>
        </HBox>
    </VBox>

    <ScrollPane fitToHeight="false" fitToWidth="true"
                style="-fx-background-color: #F0F4F1; -fx-background: #F0F4F1; -fx-border-color: transparent;">
        <VBox spacing="18" style="-fx-padding: 20 24 24 24;">

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Rectangle width="4" height="18" arcWidth="2" arcHeight="2" fill="#1B5E20"/>
                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #37474F;" text="Indicadores Clave"/>
            </HBox>

            <GridPane hgap="12" vgap="12">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="200" percentWidth="25"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="200" percentWidth="25"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="200" percentWidth="25"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="200" percentWidth="25"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="ALWAYS"/>
                    <RowConstraints vgrow="ALWAYS"/>
                </rowConstraints>

                <VBox spacing="6"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 14 14 12 14;">
                    <HBox alignment="CENTER" spacing="10">
                        <Label style="-fx-background-color: #E8F5E9; -fx-background-radius: 8;
                                      -fx-padding: 6 7 6 7; -fx-font-size: 16px; -fx-min-width: 30;
                                      -fx-alignment: center; -fx-min-height: 30;" text="🛒"/>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #90A4AE;"
                                   text="VENTAS DE HOY"/>
                            <Label fx:id="lblVentasHoy"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="0"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="6"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 14 14 12 14;" GridPane.columnIndex="1">
                    <HBox alignment="CENTER" spacing="10">
                        <Label style="-fx-background-color: #E8F5E9; -fx-background-radius: 8;
                                      -fx-padding: 6 7 6 7; -fx-font-size: 16px; -fx-min-width: 30;
                                      -fx-alignment: center; -fx-min-height: 30;" text="📦"/>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #90A4AE;"
                                   text="PRODUCTOS"/>
                            <Label fx:id="lblProductos"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="0"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="6"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 14 14 12 14;" GridPane.columnIndex="2">
                    <HBox alignment="CENTER" spacing="10">
                        <Label style="-fx-background-color: #E8F5E9; -fx-background-radius: 8;
                                      -fx-padding: 6 7 6 7; -fx-font-size: 16px; -fx-min-width: 30;
                                      -fx-alignment: center; -fx-min-height: 30;" text="👥"/>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #90A4AE;"
                                   text="CLIENTES"/>
                            <Label fx:id="lblClientes"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="0"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="6"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 14 14 12 14;" GridPane.columnIndex="3">
                    <HBox alignment="CENTER" spacing="10">
                        <Label style="-fx-background-color: #E8F5E9; -fx-background-radius: 8;
                                      -fx-padding: 6 7 6 7; -fx-font-size: 16px; -fx-min-width: 30;
                                      -fx-alignment: center; -fx-min-height: 30;" text="👨‍⚕️"/>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #90A4AE;"
                                   text="EMPLEADOS"/>
                            <Label fx:id="lblEmpleados"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="0"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="6"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 14 14 12 14;" GridPane.rowIndex="1">
                    <HBox alignment="CENTER" spacing="10">
                        <Label style="-fx-background-color: #E8F5E9; -fx-background-radius: 8;
                                      -fx-padding: 6 7 6 7; -fx-font-size: 16px; -fx-min-width: 30;
                                      -fx-alignment: center; -fx-min-height: 30;" text="⚠️"/>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #90A4AE;"
                                   text="STOCK BAJO"/>
                            <Label fx:id="lblStockBajo"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="0"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="6"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 14 14 12 14;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <HBox alignment="CENTER" spacing="10">
                        <Label style="-fx-background-color: #E8F5E9; -fx-background-radius: 8;
                                      -fx-padding: 6 7 6 7; -fx-font-size: 16px; -fx-min-width: 30;
                                      -fx-alignment: center; -fx-min-height: 30;" text="📋"/>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #90A4AE;"
                                   text="VENTAS TOTALES"/>
                            <Label fx:id="lblVentasTotal"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="0"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="6"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 14 14 12 14;" GridPane.columnIndex="2" GridPane.rowIndex="1">
                    <HBox alignment="CENTER" spacing="10">
                        <Label style="-fx-background-color: #E8F5E9; -fx-background-radius: 8;
                                      -fx-padding: 6 7 6 7; -fx-font-size: 16px; -fx-min-width: 30;
                                      -fx-alignment: center; -fx-min-height: 30;" text="⏳"/>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #90A4AE;"
                                   text="COMPRAS PENDIENTES"/>
                            <Label fx:id="lblComprasPend"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="0"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="6"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 14 14 12 14;" GridPane.columnIndex="3" GridPane.rowIndex="1">
                    <HBox alignment="CENTER" spacing="10">
                        <Label style="-fx-background-color: #E8F5E9; -fx-background-radius: 8;
                                      -fx-padding: 6 7 6 7; -fx-font-size: 16px; -fx-min-width: 30;
                                      -fx-alignment: center; -fx-min-height: 30;" text="💰"/>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #90A4AE;"
                                   text="INGRESOS TOTALES"/>
                            <Label fx:id="lblIngresos"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"
                                   text="RD$ 0.00"/>
                        </VBox>
                    </HBox>
                </VBox>
            </GridPane>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Rectangle width="4" height="18" arcWidth="2" arcHeight="2" fill="#1B5E20"/>
                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #37474F;" text="Ultimas Ventas"/>
            </HBox>

            <TableView fx:id="tblUltimasVentas" prefHeight="150"
                       style="-fx-background-color: transparent; -fx-background-radius: 8;
                              -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-border-width: 1;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 4, 0, 0, 2);">
                <columns>
                    <TableColumn fx:id="colVentaId" prefWidth="100" text="Venta"/>
                    <TableColumn fx:id="colCliente" prefWidth="220" text="Cliente"/>
                    <TableColumn fx:id="colMonto" prefWidth="150" text="Monto"/>
                    <TableColumn fx:id="colFecha" prefWidth="120" text="Fecha"/>
                </columns>
            </TableView>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Rectangle width="4" height="18" arcWidth="2" arcHeight="2" fill="#1B5E20"/>
                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #37474F;" text="Alertas del Sistema"/>
            </HBox>

            <VBox spacing="6"
                  style="-fx-background-color: #FFF8E1; -fx-background-radius: 8;
                         -fx-border-color: #FFE082; -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-padding: 14 18 14 18;">
                <Label fx:id="lblAlertas"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #E65100;"
                       text="Cargando..."/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
