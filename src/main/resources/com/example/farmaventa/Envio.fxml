<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0"
      style="-fx-background-color: #F4F6F8;"
      minHeight="650"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="com.example.farmaventa.EnvioController">

    <!-- ENCABEZADO -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>
        <VBox spacing="2">
            <Label text="Gestión de Envíos"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
            <Label text="Registra y administra los envíos de ventas"
                   style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="● Módulo de Envíos"
               style="-fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-weight: bold;
                      -fx-background-color: #E8F5E9; -fx-background-radius: 20;
                      -fx-padding: 4 12 4 12;"/>
    </HBox>

    <!-- CUERPO: 2 columnas — formulario+acciones | tabla -->
    <HBox spacing="16" VBox.vgrow="ALWAYS" minHeight="580">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <!-- ── COLUMNA IZQUIERDA: formulario + acciones ── -->
        <VBox spacing="12" prefWidth="270"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                     -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>

            <Label text="Datos del Envío"
                   style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;"/>
            <Separator/>

            <!-- ID Venta -->
            <VBox spacing="4">
                <Label text="ID Venta *" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <HBox spacing="6">
                    <TextField fx:id="txtIdVenta" promptText="Ej. 5"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-radius: 6; -fx-border-radius: 6;
                                      -fx-border-color: #E0E0E0; -fx-border-width: 1;"/>
                    <Button text="🔍" onAction="#onBuscarVenta"
                            style="-fx-background-color: #2E7D32; -fx-text-fill: white;
                                   -fx-background-radius: 6; -fx-cursor: hand;
                                   -fx-padding: 6 10 6 10;"/>
                </HBox>
                <Label fx:id="lblInfoVenta" text="" wrapText="true"
                       style="-fx-font-size: 11px; -fx-text-fill: #2E7D32;"/>
            </VBox>

            <!-- Persona que recibe -->
            <VBox spacing="4">
                <Label text="Persona que Recibe *"
                       style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <TextField fx:id="txtPersonaRecibe" promptText="Nombre completo"
                           style="-fx-background-radius: 6; -fx-border-radius: 6;
                                  -fx-border-color: #E0E0E0; -fx-border-width: 1;"/>
            </VBox>

            <!-- Método de envío -->
            <VBox spacing="4">
                <Label text="Método de Envío *"
                       style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <ComboBox fx:id="cmbMetodoEnvio" promptText="Seleccionar..."
                          maxWidth="Infinity" style="-fx-background-radius: 6;"/>
            </VBox>

            <!-- Costo -->
            <VBox spacing="4">
                <Label text="Costo del Servicio (RD$) *"
                       style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <TextField fx:id="txtCostoServicio" promptText="Ej. 150.00"
                           style="-fx-background-radius: 6; -fx-border-radius: 6;
                                  -fx-border-color: #E0E0E0; -fx-border-width: 1;"/>
            </VBox>

            <!-- Fecha -->
            <VBox spacing="4">
                <Label text="Fecha de Envío *"
                       style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <DatePicker fx:id="dpFechaEnvio" maxWidth="Infinity"
                            style="-fx-background-radius: 6;"/>
            </VBox>

            <!-- Cambiar estado -->
            <VBox spacing="4">
                <Label text="Cambiar Estado"
                       style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <HBox spacing="6">
                    <ComboBox fx:id="cmbEstado" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                              style="-fx-background-radius: 6;"/>
                    <Button text="✔" onAction="#onCambiarEstado"
                            style="-fx-background-color: #388E3C; -fx-text-fill: white;
                                   -fx-background-radius: 6; -fx-cursor: hand;
                                   -fx-font-weight: bold; -fx-padding: 6 10 6 10;"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>

            <!-- BOTONES DE ACCIÓN dentro del formulario -->
            <Button text="✔  Guardar Nuevo"
                    onAction="#onGuardarEnvio" maxWidth="Infinity"
                    style="-fx-background-color: #388E3C; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 6; -fx-cursor: hand;
                           -fx-padding: 10 0 10 0;"/>

            <Button text="✏  Editar Envío"
                    onAction="#onEditarEnvio" maxWidth="Infinity"
                    style="-fx-background-color: #E8F5E9; -fx-text-fill: #1B5E20;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 6; -fx-border-color: #C8E6C9;
                           -fx-cursor: hand; -fx-padding: 10 0 10 0;"/>

            <Button text="🗑  Eliminar Envío"
                    onAction="#onEliminarEnvio" maxWidth="Infinity"
                    style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;
                           -fx-font-size: 12px; -fx-background-radius: 6;
                           -fx-border-color: #FFCDD2; -fx-cursor: hand;
                           -fx-padding: 9 0 9 0;"/>

            <Button text="🔄  Limpiar"
                    onAction="#limpiar" maxWidth="Infinity"
                    style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;
                           -fx-font-size: 12px; -fx-background-radius: 6;
                           -fx-cursor: hand; -fx-padding: 9 0 9 0;"/>
        </VBox>

        <!-- ── COLUMNA DERECHA: Tabla (ocupa todo el ancho restante) ── -->
        <VBox spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                     -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Envíos Registrados"
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtBuscar" promptText="🔍  Buscar envío..."
                           prefWidth="230"
                           style="-fx-background-radius: 20; -fx-border-radius: 20;
                                  -fx-border-color: #E0E0E0; -fx-border-width: 1;
                                  -fx-padding: 5 12 5 12;"/>
            </HBox>
            <Separator/>

            <TableView fx:id="tablaEnvios" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId"            text="#"          prefWidth="50"/>
                    <TableColumn fx:id="colInfoVenta"     text="Venta"      prefWidth="200"/>
                    <TableColumn fx:id="colPersonaRecibe" text="Recibe"     prefWidth="140"/>
                    <TableColumn fx:id="colMetodo"        text="Método"     prefWidth="120"/>
                    <TableColumn fx:id="colCosto"         text="Costo RD$"  prefWidth="90"/>
                    <TableColumn fx:id="colFecha"         text="Fecha"      prefWidth="100"/>
                    <TableColumn fx:id="colEstado"        text="Estado"     prefWidth="120"/>
                </columns>
                <placeholder>
                    <Label text="No hay envíos registrados aún 🚚"
                           style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>
        </VBox>

    </HBox>
</VBox>
