<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox minHeight="650" spacing="0" style="-fx-background-color: #F4F6F8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.farmaventa.EnvioController">

    <!-- ENCABEZADO -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #FFFFFF;                  -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <padding><Insets bottom="18" left="24" right="24" top="18" /></padding>
        <VBox spacing="2">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="Gestión de Envíos" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;" text="Registra y administra los envíos de ventas" />
        </VBox>
    </HBox>

    <HBox minHeight="580" spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

        <!-- ── FORMULARIO (igual ancho que Inventario) ── -->
        <VBox prefWidth="290" spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);                      -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

            <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Registro de Envío" />
            <Separator />

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Venta" />
                <HBox spacing="8">
                    <TextField fx:id="txtIdVenta" promptText="Ej. 5" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" HBox.hgrow="ALWAYS" />
                    <Button onAction="#onBuscarVenta" prefHeight="27.0" prefWidth="48.0" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                    -fx-font-weight: bold; -fx-font-size: 12px;                                    -fx-background-radius: 6; -fx-cursor: hand;                                    -fx-padding: 0 12 0 12;" text="🔍" />
                </HBox>
                <Label fx:id="lblInfoVenta" style="-fx-font-size: 11px; -fx-text-fill: #2E7D32;" text="" wrapText="true" />
            </VBox>

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Persona que Recibe" />
                <TextField fx:id="txtPersonaRecibe" promptText="Nombre completo" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
            </VBox>

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Método de Envío" />
                <ComboBox fx:id="cmbMetodoEnvio" maxWidth="Infinity" promptText="Seleccionar..." style="-fx-background-radius: 6;" />
            </VBox>

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Costo del Servicio (RD$)" />
                <TextField fx:id="txtCostoServicio" promptText="0.00" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
            </VBox>

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Fecha de Envío" />
                <DatePicker fx:id="dpFechaEnvio" maxWidth="Infinity" style="-fx-background-radius: 6;" />
            </VBox>

            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Estado" />
                <ComboBox fx:id="cmbEstado" maxWidth="Infinity" promptText="Seleccionar estado..." style="-fx-background-radius: 6;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
            <Separator />

            <!-- BOTONES — igual que Inventario -->
            <HBox spacing="8">
                <Button maxWidth="Infinity" onAction="#onGuardarEnvio" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                -fx-font-weight: bold; -fx-background-radius: 6;                                -fx-cursor: hand; -fx-padding: 10 0 10 0;" text="💾  Guardar Envío" HBox.hgrow="ALWAYS" />
                <Button onAction="#limpiar" style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;                                -fx-background-radius: 6; -fx-cursor: hand;                                -fx-padding: 10 14 10 14;" text="✖" />
            </HBox>
        </VBox>

        <!-- ── TABLA ── -->
        <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);                      -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
            <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Envíos Registrados" />
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtBuscar" prefWidth="220" promptText="🔍 Buscar envío..." style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
            </HBox>
            <Separator />

            <TableView fx:id="tablaEnvios" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="50" text="#" />
                    <TableColumn fx:id="colInfoVenta" prefWidth="200" text="Venta" />
                    <TableColumn fx:id="colPersonaRecibe" prefWidth="140" text="Recibe" />
                    <TableColumn fx:id="colMetodo" prefWidth="120" text="Método" />
                    <TableColumn fx:id="colCosto" prefWidth="90" text="Costo RD$" />
                    <TableColumn fx:id="colFecha" prefWidth="100" text="Fecha" />
                    <TableColumn fx:id="colEstado" prefWidth="120" text="Estado" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;" text="No hay envíos registrados aún 🚚" />
                </placeholder>
            </TableView>

            <!-- BOTONES INFERIORES — igual que Inventario -->
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#onEditarEnvio" style="-fx-background-color: #E3F2FD; -fx-text-fill: #1565C0;                                -fx-font-weight: bold; -fx-font-size: 12px;                                -fx-background-radius: 6; -fx-border-color: #BBDEFB;                                -fx-cursor: hand; -fx-padding: 8 14 8 14;" text="✏  Editar Envío" />
                <Button onAction="#onEliminarEnvio" style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;                                -fx-border-color: #FFCDD2; -fx-font-size: 12px;                                -fx-background-radius: 6; -fx-cursor: hand;                                -fx-padding: 8 14 8 14;" text="🗑  Eliminar Envío" />
            </HBox>
        </VBox>

    </HBox>
</VBox>
