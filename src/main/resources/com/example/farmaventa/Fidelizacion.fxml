<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0"
      style="-fx-background-color: #F4F6F8;"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="com.example.farmaventa.FidelizacionController">

    <!-- ══════  ENCABEZADO  ══════ -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
        <VBox spacing="2">
            <Label text="Sistema de Fidelización"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
            <Label text="Gestiona puntos, canjes y recompensas de tus clientes"
                   style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblContActivo" text="✔  0  Activos"
               style="-fx-background-color: #E8F5E9; -fx-text-fill: #2E7D32;
                      -fx-background-radius: 20; -fx-padding: 5 14 5 14;
                      -fx-font-size: 12px; -fx-font-weight: bold;"/>
        <Label fx:id="lblContVencido" text="✖  0  Vencidos"
               style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;
                      -fx-background-radius: 20; -fx-padding: 5 14 5 14;
                      -fx-font-size: 12px; -fx-font-weight: bold;"/>
        <Label fx:id="lblTotalPuntos" text="⭐  0  Puntos totales"
               style="-fx-background-color: #FFF8E1; -fx-text-fill: #F57F17;
                      -fx-background-radius: 20; -fx-padding: 5 14 5 14;
                      -fx-font-size: 12px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- ══════  FORMULARIO  ══════ -->
    <VBox style="-fx-background-color: #FFFFFF;
                 -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

        <Label text="Registrar / Gestionar Fidelización"
               style="-fx-font-weight: bold; -fx-font-size: 14px;
                      -fx-text-fill: #2E7D32; -fx-padding: 0 0 12 0;"/>

        <HBox spacing="16">
            <!-- ID Fidelización -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="ID Fidelización" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <TextField fx:id="txtIdFidelizacion" promptText="Automático" editable="false"
                           style="-fx-background-color: #F5F5F5; -fx-background-radius: 6;
                                  -fx-border-color: #E0E0E0; -fx-border-radius: 6;
                                  -fx-text-fill: #9E9E9E; -fx-pref-height: 34;"/>
            </VBox>

            <!-- ID Cliente + buscar -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="ID Cliente *" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <HBox spacing="6">
                    <TextField fx:id="txtIdCliente" promptText="Ej. 12" HBox.hgrow="ALWAYS"
                               style="-fx-background-radius: 6; -fx-border-color: #E0E0E0;
                                      -fx-border-radius: 6; -fx-pref-height: 34;"/>
                    <Button text="🔎  Buscar" onAction="#onBuscarCliente"
                            style="-fx-background-color: #E8F5E9; -fx-text-fill: #1B5E20;
                                   -fx-background-radius: 6; -fx-cursor: hand;
                                   -fx-font-size: 12px; -fx-pref-height: 34; -fx-padding: 0 14 0 14;"/>
                </HBox>
            </VBox>

            <!-- Nombre cliente (solo lectura) -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Cliente" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <TextField fx:id="txtNombreCliente" promptText="Se llena al buscar" editable="false"
                           style="-fx-background-color: #F5F5F5; -fx-background-radius: 6;
                                  -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-pref-height: 34;"/>
            </VBox>

            <!-- Puntos -->
            <VBox spacing="5" prefWidth="130">
                <Label text="Puntos a Agregar *" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <TextField fx:id="txtPuntos" promptText="Ej. 150"
                           style="-fx-background-radius: 6; -fx-border-color: #E0E0E0;
                                  -fx-border-radius: 6; -fx-pref-height: 34;"/>
            </VBox>

            <!-- Fecha caducidad -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Fecha Caducidad *" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <DatePicker fx:id="dpFechaCaducidad" maxWidth="Infinity"
                            style="-fx-background-radius: 6; -fx-pref-height: 34;"/>
            </VBox>
        </HBox>

        <!-- Botones -->
        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 14 0 0 0;">
            <Button text="📋  Registrar Nuevo" onAction="#onRegistrar"
                    style="-fx-background-color: #388E3C; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 6; -fx-cursor: hand;
                           -fx-pref-height: 34; -fx-padding: 0 20 0 20;"/>
            <Button text="➕  Agregar Puntos" onAction="#onAgregarPuntos"
                    style="-fx-background-color: #1565C0; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 6; -fx-cursor: hand;
                           -fx-pref-height: 34; -fx-padding: 0 20 0 20;"/>
            <Button text="📅  Renovar Caducidad" onAction="#onRenovarCaducidad"
                    style="-fx-background-color: #E3F2FD; -fx-text-fill: #1565C0;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 6; -fx-cursor: hand;
                           -fx-pref-height: 34; -fx-padding: 0 20 0 20;"/>
            <Button text="✖  Limpiar" onAction="#onLimpiar"
                    style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;
                           -fx-background-radius: 6; -fx-cursor: hand;
                           -fx-pref-height: 34; -fx-padding: 0 16 0 16;"/>
        </HBox>
    </VBox>

    <!-- ══════  TABLA + PANEL LATERAL  ══════ -->
    <HBox spacing="16" VBox.vgrow="ALWAYS" minHeight="400">
        <padding><Insets top="18" right="20" bottom="20" left="20"/></padding>

        <!-- ── Tabla ── -->
        <VBox spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);
                     -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Clientes Fidelizados"
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cmbFiltroEstado" promptText="Todos los estados"
                          style="-fx-background-radius: 6;" prefWidth="150"/>
                <TextField fx:id="txtBusqueda" prefWidth="220"
                           promptText="🔍 Buscar por ID, cliente..."
                           style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
            </HBox>
            <Separator/>

            <TableView fx:id="tablaFidelizacion" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"         prefWidth="55"/>
                    <TableColumn fx:id="colCliente"  text="ID Cliente" prefWidth="90"/>
                    <TableColumn fx:id="colNombre"   text="Cliente"    prefWidth="180"/>
                    <TableColumn fx:id="colPuntos"   text="Puntos"     prefWidth="100"/>
                    <TableColumn fx:id="colCaducidad" text="Caducidad" prefWidth="110"/>
                    <TableColumn fx:id="colEstado"   text="Estado"     prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="No hay clientes fidelizados registrados"
                           style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>

            <!-- Botón eliminar -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="🗑  Eliminar" onAction="#onEliminar"
                        style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;
                               -fx-font-size: 12px; -fx-background-radius: 6;
                               -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
            </HBox>
        </VBox>

        <!-- ── Panel lateral: Detalle + Canjear ── -->
        <VBox spacing="12" prefWidth="300" minWidth="280"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);
                     -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <!-- Encabezado -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="2">
                    <Label text="Detalle del Cliente"
                           style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;"/>
                    <Label text="Historial y nivel de fidelización"
                           style="-fx-font-size: 10px; -fx-text-fill: #BDBDBD;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblHistorialDe" text="—"
                       style="-fx-font-size: 11px; -fx-text-fill: #9E9E9E;
                              -fx-background-color: #F5F5F5; -fx-background-radius: 12;
                              -fx-padding: 3 10 3 10;"/>
            </HBox>
            <Separator/>

            <!-- Lista de detalle -->
            <ListView fx:id="listHistorial" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent; -fx-border-color: #F0F0F0;
                             -fx-border-radius: 6; -fx-background-radius: 6;">
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="⭐" style="-fx-font-size: 28px;"/>
                        <Label text="Selecciona un cliente"
                               style="-fx-text-fill: #BDBDBD; -fx-font-size: 12px;"/>
                    </VBox>
                </placeholder>
            </ListView>

            <Separator/>

            <!-- Panel canjear puntos -->
            <VBox spacing="8"
                  style="-fx-background-color: #FFF8E1; -fx-background-radius: 8;
                         -fx-border-color: #FFE082; -fx-border-radius: 8; -fx-border-width: 1;">
                <padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
                <Label text="🔄  Canjear Puntos"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #E65100;"/>
                <Label fx:id="lblPuntosRestantes" text="Restantes: —"
                       style="-fx-font-size: 11px; -fx-text-fill: #BF360C; -fx-font-weight: bold;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="txtPuntosACanjear"
                               promptText="Puntos a canjear"
                               onKeyReleased="#onCanjearInput"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-radius: 6; -fx-border-color: #FFD54F;
                                      -fx-border-radius: 6; -fx-pref-height: 34;"/>
                    <Button text="Canjear ✔" onAction="#onCanjearPuntos"
                            style="-fx-background-color: #E65100; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 6;
                                   -fx-cursor: hand; -fx-pref-height: 34; -fx-padding: 0 14 0 14;"/>
                </HBox>
            </VBox>

            <!-- Leyenda niveles -->
            <VBox spacing="5"
                  style="-fx-background-color: #F9FBE7; -fx-background-radius: 8;
                         -fx-border-color: #F0F4C3; -fx-border-radius: 8; -fx-border-width: 1;">
                <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                <Label text="🏆  Niveles de Cliente"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #827717;"/>
                <Label text="🥇 ORO      →  1000+ puntos"
                       style="-fx-font-size: 11px; -fx-text-fill: #5D4037;"/>
                <Label text="🥈 PLATA    →  500 - 999 pts"
                       style="-fx-font-size: 11px; -fx-text-fill: #5D4037;"/>
                <Label text="🥉 BRONCE   →  100 - 499 pts"
                       style="-fx-font-size: 11px; -fx-text-fill: #5D4037;"/>
                <Label text="⚪ BÁSICO   →  0 - 99 pts"
                       style="-fx-font-size: 11px; -fx-text-fill: #5D4037;"/>
                <Label text="💰 100 pts = RD$ 50 de descuento"
                       style="-fx-font-size: 11px; -fx-text-fill: #2E7D32; -fx-font-weight: bold;"/>
            </VBox>

        </VBox>
    </HBox>
</VBox>
