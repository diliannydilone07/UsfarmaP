<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Inventario.fxml — Gestión de Productos
    Controlador: com.example.farmaventa.ProductoController
-->

<VBox spacing="0"
      style="-fx-background-color: #F4F6F8;"
      minHeight="650"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="com.example.farmaventa.ProductoController">

    <!-- ── Encabezado de sección ── -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>
        <VBox spacing="2">
            <Label text="Gestión de Inventario"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
            <Label text="Administra el stock de productos de la farmacia"
                   style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;"/>
        </VBox>
    </HBox>

    <!-- ── Cuerpo ── -->
    <HBox spacing="16" VBox.vgrow="ALWAYS" minHeight="580">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <!-- ────  FORMULARIO  ──── -->
        <VBox spacing="12" prefWidth="290"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                     -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>

            <Label text="Registro de Producto"
                   style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;"/>
            <Separator/>

            <VBox spacing="4">
                <Label text="ID Producto" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <TextField fx:id="txtId" promptText="Automático o manual"
                           style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Nombre del Producto *" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <TextField fx:id="txtNombre" promptText="Ej. Paracetamol 500mg"
                           style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Categoría *" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <ComboBox fx:id="cmbCategoria" maxWidth="Infinity" promptText="Seleccionar..."
                          style="-fx-background-radius: 6;"/>
            </VBox>

            <HBox spacing="8">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Stock Disponible" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                    <TextField fx:id="txtStockActual" promptText="0"
                               style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Stock Mínimo" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                    <TextField fx:id="txtStockMinimo" promptText="5"
                               style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
                </VBox>
            </HBox>

            <VBox spacing="4">
                <Label text="Precio de Venta (RD$)" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <TextField fx:id="txtPrecio" promptText="0.00"
                           style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Descuento (%)" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <TextField fx:id="txtDescuento" promptText="0"
                           style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Ubicación en almacén" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                <TextField fx:id="txtUbicacion" promptText="Ej. Pasillo A - Estante 3"
                           style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>

            <HBox spacing="8">
                <Button onAction="#onGuardarProductoClick"
                        text="💾  Guardar Producto"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-background-color: #388E3C; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 6;
                               -fx-cursor: hand; -fx-padding: 10 0 10 0;"/>
                <Button text="✖"
                        style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 10 14 10 14;"/>
            </HBox>
        </VBox>

        <!-- ────  TABLA  ──── -->
        <VBox spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                     -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Inventario General"
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Filtro por categoría -->
                <ComboBox promptText="Categoría"
                          style="-fx-background-radius: 6;" prefWidth="130"/>
                <TextField fx:id="txtBusqueda" prefWidth="220"
                           promptText="🔍 Buscar por nombre o ID..."
                           style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;"/>
            </HBox>
            <Separator/>

            <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId"        text="ID"         prefWidth="55"/>
                    <TableColumn fx:id="colNombre"    text="Nombre"     prefWidth="180"/>
                    <TableColumn fx:id="colCategoria" text="Categoría"  prefWidth="120"/>
                    <TableColumn fx:id="colStock"     text="Stock"      prefWidth="70"/>
                    <TableColumn fx:id="colMinimo"    text="Mín."       prefWidth="60"/>
                    <TableColumn fx:id="colPrecio"    text="Precio"     prefWidth="90"/>
                    <TableColumn fx:id="colDescuento" text="Desc. %"    prefWidth="70"/>
                    <TableColumn fx:id="colUbicacion" text="Ubicación"  prefWidth="120"/>
                </columns>
                <placeholder>
                    <Label text="No hay productos en el inventario"
                           style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>

            <!-- Barra de acciones de tabla -->
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Label text="Cantidad:" style="-fx-font-size: 12px; -fx-text-fill: #757575;"/>
                <Spinner fx:id="spinCantidad" prefWidth="80"
                         style="-fx-background-radius: 6;"/>
                <Button onAction="#onAñadirClick"
                        text="🛒  Añadir a Venta"
                        style="-fx-background-color: #E8F5E9; -fx-text-fill: #1B5E20;
                               -fx-font-weight: bold; -fx-font-size: 12px;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 8 14 8 14;"/>
                <Button onAction="#onCancelarClick"
                        text="🗑  Eliminar Producto"
                        style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;
                               -fx-border-color: #FFCDD2; -fx-font-size: 12px;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 8 14 8 14;"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
