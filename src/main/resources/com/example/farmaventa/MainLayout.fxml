<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<BorderPane minHeight="600" minWidth="900" prefHeight="750" prefWidth="1200"
            style="-fx-background-color: #F0F4F1;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.farmaventa.controlador.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" maxHeight="68" minHeight="68" prefHeight="68" spacing="0"
              style="-fx-background-color: #FFFFFF;
                     -fx-border-color: #E8E8E8;
                     -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 6, 0, 0, 2);">

            <HBox alignment="CENTER_LEFT" maxHeight="68" minHeight="68" prefHeight="68"
                  maxWidth="260" minWidth="260" prefWidth="260"
                  style="-fx-background-color: #1B5E20; -fx-padding: 0 24 0 24;">
                <ImageView fx:id="imgLogo" fitHeight="48" preserveRatio="true" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" maxHeight="34" minHeight="34" prefHeight="34" spacing="6"
                  style="-fx-background-color: #F5FAF5; -fx-background-radius: 10;
                         -fx-border-color: #E0EDE0; -fx-border-radius: 10; -fx-border-width: 1;
                         -fx-padding: 0 16 0 12;">
                <Label style="-fx-text-fill: #388E3C; -fx-font-size: 14px;" text="📅" />
                <Label fx:id="lblFecha"
                       style="-fx-text-fill: #2E7D32; -fx-font-size: 13px; -fx-font-weight: 600;"
                       text="25/04/2026" />
            </HBox>

            <Region maxWidth="10" minWidth="10" />

            <HBox alignment="CENTER" maxHeight="34" minHeight="34" prefHeight="34" spacing="8"
                  style="-fx-background-color: #F5FAF5; -fx-background-radius: 10;
                         -fx-border-color: #E0EDE0; -fx-border-radius: 10; -fx-border-width: 1;
                         -fx-padding: 0 16 0 8;">
                <StackPane maxHeight="24" maxWidth="24" minHeight="24" minWidth="24"
                           style="-fx-background-color: #2E7D32; -fx-background-radius: 50;">
                    <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 11px; -fx-font-weight: bold;"
                           text="JP" />
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="0">
                    <Label fx:id="lblUsuario"
                           style="-fx-text-fill: #1B5E20; -fx-font-size: 12px; -fx-font-weight: bold;"
                           text="Juan Pérez García"/>
                    <HBox alignment="CENTER_LEFT" spacing="4">
                        <Label style="-fx-text-fill: #43A047; -fx-font-size: 7px;" text="●" />
                        <Label style="-fx-text-fill: #90A4AE; -fx-font-size: 10px;" text="En línea" />
                    </HBox>
                </VBox>
            </HBox>

            <Region maxWidth="10" minWidth="10" />

            <Button onAction="#onCerrarSesion"
                    style="-fx-background-color: #FFF5F5; -fx-text-fill: #E53935;
                           -fx-font-size: 13px; -fx-font-weight: 600;
                           -fx-background-radius: 10; -fx-border-color: #FFCDD2;
                           -fx-border-radius: 10; -fx-border-width: 1; -fx-cursor: hand;
                           -fx-padding: 6 18 6 14;" text="⏻  Salir" />

            <Region maxWidth="24" minWidth="24" />
        </HBox>
    </top>

    <center>
        <HBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxWidth="260" minWidth="260" prefWidth="260"
                        style="-fx-background-color: #1B5E20; -fx-background: #1B5E20; -fx-border-color: transparent;"
                        vbarPolicy="AS_NEEDED">

                <VBox maxWidth="260" minWidth="260" prefWidth="260" spacing="2"
                      style="-fx-background-color: #1B5E20;">
                    <padding><Insets bottom="24" left="14" right="14" top="24" /></padding>

                    <Label style="-fx-font-size: 10px; -fx-text-fill: rgba(165,214,167,0.5);
                                  -fx-font-weight: bold; -fx-padding: 0 8 8 10;"
                           text="PRINCIPAL" />

                    <Button fx:id="btnInicio" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuInicio"
                            style="-fx-background-color: #2E7D32; -fx-text-fill: #FFFFFF;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="🏠  Inicio" />

                    <Button fx:id="btnVentas" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuVentas"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="🛒  Ventas" />

                    <Button fx:id="btnCompras" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuCompras"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="📥  Compras" />

                    <Button fx:id="btnPagos" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuPagos"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="💳  Pagos" />

                    <Button fx:id="btnNomina" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuNomina"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="💰  Nómina" />

                    <Button fx:id="btnPersonas" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuPersonas"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="👥  Personas" />

                    <Button fx:id="btnInventario" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuInventario"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="📦  Inventario" />

                    <Pane maxHeight="1" minHeight="1" prefHeight="1"
                          style="-fx-background-color: rgba(165,214,167,0.1);">
                        <VBox.margin><Insets bottom="12" top="12" /></VBox.margin>
                    </Pane>

                    <Label style="-fx-font-size: 10px; -fx-text-fill: rgba(165,214,167,0.5);
                                  -fx-font-weight: bold; -fx-padding: 0 8 8 10;"
                           text="GESTIÓN" />

                    <Button fx:id="btnReclamacionesToggle" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onToggleReclamaciones"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="📋  Reclamaciones  ›" />

                    <VBox fx:id="vboxReclamaciones" managed="false" spacing="2" visible="false">
                        <padding><Insets bottom="4" left="20" top="4" /></padding>
                        <Button fx:id="btnReclamaciones" alignment="CENTER_LEFT" maxWidth="Infinity"
                                onAction="#onMenuReclamaciones"
                                style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: #81C784;
                                       -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-padding: 9 14 9 14;" text="↳  Ventas" />
                        <Button fx:id="btnReclamacionesCompra" alignment="CENTER_LEFT" maxWidth="Infinity"
                                onAction="#onMenuReclamacionesCompra"
                                style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: #81C784;
                                       -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-padding: 9 14 9 14;" text="↳  Compras" />
                    </VBox>

                    <Button fx:id="btnDevolucionesToggle" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onToggleDevoluciones"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="↩  Devoluciones  ›" />

                    <VBox fx:id="vboxDevoluciones" managed="false" spacing="2" visible="false">
                        <padding><Insets bottom="4" left="20" top="4" /></padding>
                        <Button fx:id="btnDevoluciones" alignment="CENTER_LEFT" maxWidth="Infinity"
                                onAction="#onMenuDevoluciones"
                                style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: #81C784;
                                       -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-padding: 9 14 9 14;" text="↳  Ventas" />
                        <Button fx:id="btnDevolucionesCompra" alignment="CENTER_LEFT" maxWidth="Infinity"
                                onAction="#onMenuDevolucionesCompra"
                                style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: #81C784;
                                       -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-padding: 9 14 9 14;" text="↳  Compras" />
                    </VBox>

                    <Button fx:id="btnFidelizacion" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuFidelizacion"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="⭐  Fidelización" />

                    <Button fx:id="btnConvenios" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuConvenios"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="🤝  Convenios" />

                    <Button fx:id="btnEnvios" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuEnvios"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="🚚  Envíos" />

                    <Pane maxHeight="1" minHeight="1" prefHeight="1"
                          style="-fx-background-color: rgba(165,214,167,0.1);">
                        <VBox.margin><Insets bottom="12" top="12" /></VBox.margin>
                    </Pane>

                    <Label style="-fx-font-size: 10px; -fx-text-fill: rgba(165,214,167,0.5);
                                  -fx-font-weight: bold; -fx-padding: 0 8 8 10;"
                           text="ADMINISTRACIÓN" />

                    <Button fx:id="btnUsuarios" alignment="CENTER_LEFT" maxWidth="Infinity"
                            onAction="#onMenuUsuarios"
                            style="-fx-background-color: transparent; -fx-text-fill: #A5D6A7;
                                   -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-padding: 11 16 11 16;" text="🔐  Usuarios" />

                    <HBox alignment="CENTER_LEFT" spacing="8"
                          style="-fx-background-color: rgba(0,0,0,0.15); -fx-background-radius: 10;
                                 -fx-padding: 10 16 10 16;">
                        <VBox.margin><Insets top="20" /></VBox.margin>
                        <StackPane maxHeight="8" maxWidth="8" minHeight="8" minWidth="8"
                                   style="-fx-background-color: #66BB6A; -fx-background-radius: 50;" />
                        <Label style="-fx-text-fill: rgba(165,214,167,0.45); -fx-font-size: 11px;"
                               text="v1.0.0 · FarmaVenta" />
                    </HBox>

                </VBox>
            </ScrollPane>

            <ScrollPane fitToHeight="false" fitToWidth="true"
                        style="-fx-background-color: #F0F4F1; -fx-background: #F0F4F1;
                               -fx-border-color: transparent;"
                        HBox.hgrow="ALWAYS">

                <StackPane fx:id="contentArea" style="-fx-background-color: #F0F4F1;">
                    <VBox alignment="CENTER" spacing="16">
                        <padding><Insets top="60" /></padding>
                        <ImageView fitHeight="240" fitWidth="240" opacity="0.55" preserveRatio="true">
                            <Image url="@logologo.png" />
                        </ImageView>
                        <VBox alignment="CENTER" spacing="6">
                            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"
                                   text="Bienvenido al Sistema" />
                            <Label style="-fx-font-size: 13px; -fx-text-fill: #78909C;"
                                   text="Selecciona una opción del menú para comenzar" />
                        </VBox>
                    </VBox>
                </StackPane>
            </ScrollPane>

        </HBox>
    </center>

</BorderPane>
