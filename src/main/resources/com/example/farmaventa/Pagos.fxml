                    <Label fx:id="lblSaldoSeguro" managed="false" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #C62828;                                   -fx-background-color: #FFEBEE; -fx-background-radius: 6;                                   -fx-border-color: #FFCDD2; -fx-border-radius: 6; -fx-border-width: 1;                                   -fx-padding: 6 10 6 10;" text="" visible="false" />

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #455A64;" text="Monto a Cobrar (RD$)" />
                        <TextField fx:id="txtMontoPagoSeguro" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #C8D8C8; -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 8; -fx-pref-height: 36;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #455A64;" text="Método de Pago" />
                        <ComboBox fx:id="cmbMetodoPagoSeguro" maxWidth="Infinity" style="-fx-background-radius: 8; -fx-border-color: #C8D8C8; -fx-border-radius: 8; -fx-border-width: 1;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #455A64;" text="Fecha de Cobro" />
                        <DatePicker fx:id="dpFechaPagoSeguro" maxWidth="Infinity" style="-fx-background-radius: 8; -fx-border-color: #C8D8C8; -fx-border-radius: 8;" />
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />
                    <Separator style="-fx-background-color: #E8F5E9;" />

                    <HBox spacing="8">
                        <Button fx:id="btnPagarSeguro" maxWidth="Infinity" onAction="#onRegistrarPagoSeguro" prefHeight="42.0" prefWidth="351.0" style="-fx-background-color: #1B5E20; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 9; -fx-border-color: #145214; -fx-border-radius: 9; -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 10 18 10 18;" text="✔  Registrar " HBox.hgrow="ALWAYS" />
                        <Button onAction="#onLimpiarPagoSeguro" prefHeight="42.0" prefWidth="320.0" style="-fx-background-color: #ECEFF1; -fx-text-fill: #455A64; -fx-font-size: 13px; -fx-background-radius: 9; -fx-border-color: #CFD8DC; -fx-border-radius: 9; -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 10 16 10 16;" text="✕ Limpiar" />
                    </HBox>
                </VBox>


                <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;                              -fx-border-color: #DCE8DC; -fx-border-radius: 12; -fx-border-width: 1;                              -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.06), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1B5E20;" text="Ventas con Seguro Pendientes" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onRefrescarSeguros" style="-fx-background-color: #ECEFF1; -fx-text-fill: #455A64; -fx-font-size: 12px; -fx-background-radius: 9; -fx-border-color: #CFD8DC; -fx-border-radius: 9; -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 16 8 16;" text="↻ Refrescar" />
                    </HBox>


                    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #E8F5E9; -fx-background-radius: 6;                                  -fx-border-color: #A5D6A7; -fx-border-radius: 6; -fx-border-width: 1;                                  -fx-padding: 8 12 8 12;">
                        <Label style="-fx-font-size: 12px;" text="ℹ" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #1B5E20;" text="Cada venta genera 2 filas: Aseguradora (monto cubierto) y Cliente (copago). Selecciona la fila y elige el tipo antes de cobrar." wrapText="true" />
                    </HBox>

                    <Label fx:id="lblResumenSeguro" style="-fx-font-size: 11px; -fx-text-fill: #C62828;                                    -fx-background-color: #FFEBEE; -fx-background-radius: 6;                                    -fx-border-color: #FFCDD2; -fx-border-radius: 6; -fx-border-width: 1;                                    -fx-padding: 6 12 6 12;" text="Cargando..." />

                    <TableView fx:id="tablaSeguro" style="-fx-background-color: transparent; -fx-border-color: #E8F0E8; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colSegId" prefWidth="60" text="ID VS" />
                            <TableColumn fx:id="colSegTipo" prefWidth="100" text="Factura" />
                            <TableColumn fx:id="colSegDescripcion" prefWidth="200" text="Descripción" />
                            <TableColumn fx:id="colSegFecha" prefWidth="95" text="Fecha" />
                            <TableColumn fx:id="colSegTotal" prefWidth="100" text="Total" />
                            <TableColumn fx:id="colSegPagado" prefWidth="100" text="Pagado" />
                            <TableColumn fx:id="colSegPendiente" prefWidth="100" text="Pendiente" />
                            <TableColumn fx:id="colSegEstado" prefWidth="80" text="Estado" />
                        </columns>
                        <placeholder><Label style="-fx-text-fill: #90A4AE; -fx-font-size: 13px;" text="No hay cuentas de seguro pendientes" /></placeholder>
                    </TableView>

                    <Separator style="-fx-background-color: #E8F5E9;" />

                    <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #424242;" text="Historial de Cobros (Seguro)" />

                    <TableView fx:id="tablaHistSeguro" prefHeight="180" style="-fx-background-color: transparent;">
                        <columns>
                            <TableColumn fx:id="colHSegId" prefWidth="55" text="#" />
                            <TableColumn fx:id="colHSegFecha" prefWidth="95" text="Fecha" />
                            <TableColumn fx:id="colHSegMonto" prefWidth="110" text="Monto" />
                            <TableColumn fx:id="colHSegMetodo" prefWidth="100" text="Método" />
                            <TableColumn fx:id="colHSegTipo" prefWidth="100" text="Factura" />
                            <TableColumn fx:id="colHSegEstado" prefWidth="80" text="Estado" />
                        </columns>
                        <placeholder><Label style="-fx-text-fill: #90A4AE; -fx-font-size: 11px;" text="Selecciona una cuenta de seguro para ver su historial" /></placeholder>
                    </TableView>
                </VBox>
            </HBox>
        </Tab>

    </TabPane>
</VBox>
