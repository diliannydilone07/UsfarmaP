<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" style="-fx-background-color: #F4F6F8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.farmaventa.PagosController">

    <!-- ══ ENCABEZADO ══════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #FFFFFF;                  -fx-border-color: #E0E0E0;                  -fx-border-width: 0 0 1 0;">
        <padding><Insets bottom="18" left="24" right="24" top="18" /></padding>
        <VBox spacing="2">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="Módulo de Pagos" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;" text="Gestión de cuentas por pagar y por cobrar" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#onRefrescarCompras" style="-fx-background-color: #E8F5E9; -fx-text-fill: #2E7D32;                        -fx-font-size: 12px; -fx-background-radius: 6;                        -fx-border-color: #C8E6C9; -fx-border-radius: 6; -fx-border-width: 1;                        -fx-cursor: hand; -fx-padding: 7 14 7 14;" text="↻  Refrescar" />
    </HBox>

    <!-- ══ TAB PANE PRINCIPAL ════════════════════════════════════════════ -->
    <TabPane fx:id="tabPanePagos" style="-fx-tab-min-height: 38px; -fx-tab-max-height: 38px;" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <!-- ╔══════════════════════════════════════════════════════════════╗
             ║  PESTAÑA 0 — CUENTAS POR PAGAR (Compras a proveedores)      ║
             ╚══════════════════════════════════════════════════════════════╝ -->
        <Tab text="💸  Cuentas por Pagar">
            <HBox minHeight="580" spacing="16" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

                <!-- COLUMNA IZQUIERDA — Formulario Pago Compra -->
                <VBox prefHeight="813.0" prefWidth="282.0" spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                              -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
                    <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Registrar Pago" />
                    <Separator />

                    <!-- Búsqueda / filtro -->
                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Buscar compra" />
                        <HBox spacing="8">
                            <TextField fx:id="txtBuscarCompra" promptText="Proveedor o ID..." style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" HBox.hgrow="ALWAYS" />
                            <Button onAction="#onBuscarEnCompras" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                            -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 10 4 10;" text="Buscar" />
                        </HBox>
                        <ComboBox fx:id="cmbFiltroCompra" maxWidth="Infinity" promptText="Estado..." style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <Separator />

                    <!-- ID de compra seleccionada -->
                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Compra" />
                        <TextField fx:id="txtIdCompraPago" promptText="Se llena al seleccionar" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                        <Label fx:id="lblInfoCompraPago" style="-fx-font-size: 11px; -fx-text-fill: #2E7D32;" text="" wrapText="true" />
                    </VBox>

                    <!-- Saldo pendiente -->
                    <Label fx:id="lblSaldoCompra" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #C62828;                                   -fx-background-color: #FFEBEE; -fx-background-radius: 6;                                   -fx-border-color: #FFCDD2; -fx-border-radius: 6; -fx-border-width: 1;                                   -fx-padding: 6 10 6 10;" text="" />

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Monto a Pagar (RD$)" />
                        <TextField fx:id="txtMontoPagoCompra" promptText="0.00" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Método de Pago" />
                        <ComboBox fx:id="cmbMetodoPagoCompra" maxWidth="Infinity" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Cuenta Bancaria" />
                        <ComboBox fx:id="cmbCuentaCompra" maxWidth="Infinity" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Fecha de Pago" />
                        <DatePicker fx:id="dpFechaPagoCompra" maxWidth="Infinity" style="-fx-background-radius: 6;" />
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />
                    <Separator />

                    <HBox spacing="8">
                        <Button maxWidth="Infinity" onAction="#onRegistrarPagoCompra" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                        -fx-font-weight: bold; -fx-background-radius: 6;                                        -fx-cursor: hand; -fx-padding: 10 0 10 0;" text="✔  Registrar Pago" HBox.hgrow="ALWAYS" />
                        <Button onAction="#onLimpiarPagoCompra" style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;                                        -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10 14 10 14;" text="Limpiar" />
                    </HBox>
                </VBox>

                <!-- COLUMNA DERECHA — Tabla + Historial Compras -->
                <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                              -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Compras con Saldo Pendiente" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onRefrescarCompras" style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;                                        -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 5 10 5 10;" text="↻ Refrescar" />
                    </HBox>

                    <Label fx:id="lblResumenCompras" style="-fx-font-size: 11px; -fx-text-fill: #C62828;                                   -fx-background-color: #FFEBEE; -fx-background-radius: 6;                                   -fx-border-color: #FFCDD2; -fx-border-radius: 6; -fx-border-width: 1;                                   -fx-padding: 6 12 6 12;" text="Cargando..." />

                    <TableView fx:id="tablaCompras" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colCmpId" prefWidth="55" text="ID" />
                            <TableColumn fx:id="colCmpProveedor" prefWidth="180" text="Proveedor" />
                            <TableColumn fx:id="colCmpFecha" prefWidth="95" text="Fecha" />
                            <TableColumn fx:id="colCmpTotal" prefWidth="105" text="Total" />
                            <TableColumn fx:id="colCmpPagado" prefWidth="105" text="Pagado" />
                            <TableColumn fx:id="colCmpPendiente" prefWidth="105" text="Pendiente" />
                            <TableColumn fx:id="colCmpEstado" prefWidth="85" text="Estado" />
                        </columns>
                        <placeholder><Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;" text="No hay compras pendientes" /></placeholder>
                    </TableView>

                    <Separator />

                    <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #424242;" text="Historial de Pagos" />

                    <TableView fx:id="tablaHistCompra" prefHeight="180" style="-fx-background-color: transparent;">
                        <columns>
                            <TableColumn fx:id="colHCmpId" prefWidth="55" text="#" />
                            <TableColumn fx:id="colHCmpFecha" prefWidth="95" text="Fecha" />
                            <TableColumn fx:id="colHCmpMonto" prefWidth="110" text="Monto" />
                            <TableColumn fx:id="colHCmpMetodo" prefWidth="100" text="Método" />
                            <TableColumn fx:id="colHCmpCuenta" prefWidth="160" text="Cuenta" />
                            <TableColumn fx:id="colHCmpEstado" prefWidth="80" text="Estado" />
                        </columns>
                        <placeholder><Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 11px;" text="Selecciona una compra para ver su historial" /></placeholder>
                    </TableView>
                </VBox>
            </HBox>
        </Tab>

        <!-- ╔══════════════════════════════════════════════════════════════╗
             ║  PESTAÑA 1 — CUENTAS POR COBRAR (Ventas normales)           ║
             ║  Sin campo de cuenta bancaria                                ║
             ╚══════════════════════════════════════════════════════════════╝ -->
        <Tab text="📈  Cuentas por Cobrar">
            <HBox minHeight="580" spacing="16" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

                <!-- COLUMNA IZQUIERDA — Formulario Cobro Venta -->
                <VBox prefWidth="300" spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                              -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
                    <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Registrar Cobro" />
                    <Separator />

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Buscar venta" />
                        <HBox spacing="8">
                            <TextField fx:id="txtBuscarVenta" promptText="Cliente o ID..." style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" HBox.hgrow="ALWAYS" />
                            <Button onAction="#onBuscarEnVentas" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                            -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 10 4 10;" text="Buscar" />
                        </HBox>
                        <ComboBox fx:id="cmbFiltroVenta" maxWidth="Infinity" promptText="Estado..." style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <Separator />

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Venta" />
                        <TextField fx:id="txtIdVentaPago" promptText="Se llena al seleccionar" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                        <Label fx:id="lblInfoVentaPago" style="-fx-font-size: 11px; -fx-text-fill: #2E7D32;" text="" wrapText="true" />
                    </VBox>

                    <Label fx:id="lblSaldoVenta" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #C62828;                                   -fx-background-color: #FFEBEE; -fx-background-radius: 6;                                   -fx-border-color: #FFCDD2; -fx-border-radius: 6; -fx-border-width: 1;                                   -fx-padding: 6 10 6 10;" text="" />

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Monto a Cobrar (RD$)" />
                        <TextField fx:id="txtMontoPagoVenta" promptText="0.00" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Método de Pago" />
                        <ComboBox fx:id="cmbMetodoPagoVenta" maxWidth="Infinity" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <!-- Sin cuenta bancaria aquí -->

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Fecha de Cobro" />
                        <DatePicker fx:id="dpFechaPagoVenta" maxWidth="Infinity" style="-fx-background-radius: 6;" />
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />
                    <Separator />

                    <HBox spacing="8">
                        <Button maxWidth="Infinity" onAction="#onRegistrarPagoVenta" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                        -fx-font-weight: bold; -fx-background-radius: 6;                                        -fx-cursor: hand; -fx-padding: 10 0 10 0;" text="✔  Registrar Cobro" HBox.hgrow="ALWAYS" />
                        <Button onAction="#onLimpiarPagoVenta" style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;                                        -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10 14 10 14;" text="Limpiar" />
                    </HBox>
                </VBox>

                <!-- COLUMNA DERECHA — Tabla + Historial Ventas -->
                <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                              -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Ventas con Saldo Pendiente" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onRefrescarVentas" style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;                                        -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 5 10 5 10;" text="↻ Refrescar" />
                    </HBox>

                    <Label fx:id="lblResumenVentas" style="-fx-font-size: 11px; -fx-text-fill: #C62828;                                   -fx-background-color: #FFEBEE; -fx-background-radius: 6;                                   -fx-border-color: #FFCDD2; -fx-border-radius: 6; -fx-border-width: 1;                                   -fx-padding: 6 12 6 12;" text="Cargando..." />

                    <TableView fx:id="tablaVentas" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colVntId" prefWidth="55" text="ID" />
                            <TableColumn fx:id="colVntCliente" prefWidth="180" text="Cliente" />
                            <TableColumn fx:id="colVntFecha" prefWidth="95" text="Fecha" />
                            <TableColumn fx:id="colVntTotal" prefWidth="105" text="Total" />
                            <TableColumn fx:id="colVntPagado" prefWidth="105" text="Pagado" />
                            <TableColumn fx:id="colVntPendiente" prefWidth="105" text="Pendiente" />
                            <TableColumn fx:id="colVntEstado" prefWidth="85" text="Estado" />
                        </columns>
                        <placeholder><Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;" text="No hay ventas con saldo pendiente" /></placeholder>
                    </TableView>

                    <Separator />

                    <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #424242;" text="Historial de Cobros" />

                    <TableView fx:id="tablaHistVenta" prefHeight="180" style="-fx-background-color: transparent;">
                        <columns>
                            <TableColumn fx:id="colHVntId" prefWidth="55" text="#" />
                            <TableColumn fx:id="colHVntFecha" prefWidth="95" text="Fecha" />
                            <TableColumn fx:id="colHVntMonto" prefWidth="110" text="Monto" />
                            <TableColumn fx:id="colHVntMetodo" prefWidth="110" text="Método" />
                            <TableColumn fx:id="colHVntEstado" prefWidth="90" text="Estado" />
                        </columns>
                        <placeholder><Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 11px;" text="Selecciona una venta para ver su historial" /></placeholder>
                    </TableView>
                </VBox>
            </HBox>
        </Tab>

        <!-- ╔══════════════════════════════════════════════════════════════╗
             ║  PESTAÑA 2 — CUENTAS POR COBRAR SEGURO                      ║
             ║  Sin campo de cuenta bancaria                                ║
             ╚══════════════════════════════════════════════════════════════╝ -->
        <Tab text="🏥  Cuentas Seguro">
            <HBox minHeight="580" spacing="16" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

                <!-- COLUMNA IZQUIERDA — Formulario Cobro Seguro -->
                <VBox prefHeight="813.0" prefWidth="439.0" spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                              -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
                    <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Registrar Cobro de Seguro" />
                    <Separator />

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Buscar venta con seguro" />
                        <HBox spacing="8">
                            <TextField fx:id="txtBuscarSeguro" promptText="Aseguradora, cliente o ID..." style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" HBox.hgrow="ALWAYS" />
                            <Button onAction="#onBuscarEnSeguros" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                            -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 10 4 10;" text="Buscar" />
                        </HBox>
                        <ComboBox fx:id="cmbFiltroSeguro" maxWidth="Infinity" promptText="Estado..." style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <Separator />

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Venta Seguro" />
                        <TextField fx:id="txtIdSeguroPago" promptText="Se llena al seleccionar" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                        <Label fx:id="lblInfoSeguroPago" style="-fx-font-size: 11px; -fx-text-fill: #2E7D32;" text="" wrapText="true" />
                    </VBox>

                    <!-- Tipo de factura — campo clave -->
                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Tipo de Factura *" />
                        <ComboBox fx:id="cmbTipoFacturaSeguro" maxWidth="Infinity" style="-fx-background-radius: 6; -fx-border-color: #A5D6A7;                                          -fx-border-radius: 6; -fx-border-width: 1.5;                                          -fx-background-color: #E8F5E9;" />
                    </VBox>

                    <Label fx:id="lblSaldoSeguro" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #C62828;                                   -fx-background-color: #FFEBEE; -fx-background-radius: 6;                                   -fx-border-color: #FFCDD2; -fx-border-radius: 6; -fx-border-width: 1;                                   -fx-padding: 6 10 6 10;" text="" />

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Monto a Cobrar (RD$)" />
                        <TextField fx:id="txtMontoPagoSeguro" promptText="0.00" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Método de Pago" />
                        <ComboBox fx:id="cmbMetodoPagoSeguro" maxWidth="Infinity" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <!-- Sin cuenta bancaria aquí -->

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Fecha de Cobro" />
                        <DatePicker fx:id="dpFechaPagoSeguro" maxWidth="Infinity" style="-fx-background-radius: 6;" />
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />
                    <Separator />

                    <HBox spacing="8">
                        <Button maxWidth="Infinity" onAction="#onRegistrarPagoSeguro" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                        -fx-font-weight: bold; -fx-background-radius: 6;                                        -fx-cursor: hand; -fx-padding: 10 0 10 0;" text="✔  Registrar Cobro" HBox.hgrow="ALWAYS" />
                        <Button onAction="#onLimpiarPagoSeguro" style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;                                        -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10 14 10 14;" text="Limpiar" />
                    </HBox>
                </VBox>

                <!-- COLUMNA DERECHA — Tabla + Historial Seguro -->
                <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                              -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Ventas con Seguro Pendientes" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#onRefrescarSeguros" style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;                                        -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 5 10 5 10;" text="↻ Refrescar" />
                    </HBox>

                    <!-- Aviso explicativo -->
                    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #E8F5E9; -fx-background-radius: 6;                                  -fx-border-color: #A5D6A7; -fx-border-radius: 6; -fx-border-width: 1;                                  -fx-padding: 8 12 8 12;">
                        <Label style="-fx-font-size: 12px;" text="ℹ" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #1B5E20;" text="Cada venta genera 2 filas: Aseguradora (monto cubierto) y Cliente (copago). Selecciona la fila y elige el tipo antes de cobrar." wrapText="true" />
                    </HBox>

                    <Label fx:id="lblResumenSeguro" style="-fx-font-size: 11px; -fx-text-fill: #C62828;                                   -fx-background-color: #FFEBEE; -fx-background-radius: 6;                                   -fx-border-color: #FFCDD2; -fx-border-radius: 6; -fx-border-width: 1;                                   -fx-padding: 6 12 6 12;" text="Cargando..." />

                    <TableView fx:id="tablaSeguro" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colSegId" prefWidth="60" text="ID VS" />
