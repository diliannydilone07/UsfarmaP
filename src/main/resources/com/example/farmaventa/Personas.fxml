<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0"
      style="-fx-background-color: #F4F6F8;"
      minHeight="650"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="com.example.farmaventa.PersonaController">

    <!-- ENCABEZADO -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>
        <VBox spacing="2">
            <Label text="Gestión de Personas"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;"/>
            <Label text="Registra personas con su dirección completa"
                   style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="● Módulo de Personas"
               style="-fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-weight: bold;
                      -fx-background-color: #E8F5E9; -fx-background-radius: 20;
                      -fx-padding: 4 12 4 12;"/>
    </HBox>

    <!-- CUERPO: 2 columnas — formulario+acciones | tabla -->
    <HBox spacing="16" VBox.vgrow="ALWAYS" minHeight="580">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <!-- ── COLUMNA IZQUIERDA: scroll con formulario + botones ── -->
        <VBox prefWidth="300" minWidth="300" maxWidth="300"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                     -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-border-color: transparent;">
                <VBox spacing="10">
                    <padding><Insets top="20" right="18" bottom="10" left="18"/></padding>

                    <!-- Datos Personales -->
                    <Label text="Datos Personales"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #2E7D32;"/>
                    <Separator/>

                    <VBox spacing="3">
                        <Label text="Nombre *" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <TextField fx:id="txtNombre" promptText="Nombre"
                                   style="-fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #E0E0E0; -fx-border-width: 1;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Apellido *" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <TextField fx:id="txtApellido" promptText="Apellido"
                                   style="-fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #E0E0E0; -fx-border-width: 1;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Género *" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <ComboBox fx:id="cmbGenero" promptText="Seleccionar..."
                                  maxWidth="Infinity" style="-fx-background-radius: 6;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Teléfono" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <TextField fx:id="txtTelefono" promptText="809-000-0000"
                                   style="-fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #E0E0E0; -fx-border-width: 1;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Correo electrónico" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <TextField fx:id="txtCorreo" promptText="correo@ejemplo.com"
                                   style="-fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #E0E0E0; -fx-border-width: 1;"/>
                    </VBox>

                    <!-- Dirección -->
                    <Label text="Dirección"
                           style="-fx-font-weight: bold; -fx-font-size: 13px;
                                  -fx-text-fill: #2E7D32; -fx-padding: 6 0 0 0;"/>
                    <Separator/>

                    <VBox spacing="3">
                        <Label text="Región" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <ComboBox fx:id="cmbRegion" promptText="Seleccionar región..."
                                  maxWidth="Infinity" style="-fx-background-radius: 6;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="País" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <ComboBox fx:id="cmbPais" promptText="Seleccionar país..."
                                  maxWidth="Infinity" style="-fx-background-radius: 6;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Provincia" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <ComboBox fx:id="cmbProvincia" promptText="Seleccionar provincia..."
                                  maxWidth="Infinity" style="-fx-background-radius: 6;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Municipio" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <ComboBox fx:id="cmbMunicipio" promptText="Seleccionar municipio..."
                                  maxWidth="Infinity" style="-fx-background-radius: 6;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Distrito Municipal" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <ComboBox fx:id="cmbDistrito" promptText="Seleccionar distrito..."
                                  maxWidth="Infinity" style="-fx-background-radius: 6;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Sector" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <ComboBox fx:id="cmbSector" promptText="Seleccionar sector..."
                                  maxWidth="Infinity" style="-fx-background-radius: 6;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Calle" style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <ComboBox fx:id="cmbCalle" promptText="Seleccionar calle..."
                                  maxWidth="Infinity" style="-fx-background-radius: 6;"/>
                    </VBox>

                    <VBox spacing="3">
                        <Label text="Descripción de dirección"
                               style="-fx-font-size: 11px; -fx-text-fill: #757575;"/>
                        <TextField fx:id="txtDescripcionDireccion"
                                   promptText="Ej. Casa #5, frente al parque"
                                   style="-fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #E0E0E0; -fx-border-width: 1;"/>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- Botones fijos en la parte inferior (fuera del scroll) -->
            <VBox spacing="8">
                <padding><Insets top="10" right="18" bottom="18" left="18"/></padding>
                <Separator/>

                <Button text="✔  Guardar Nueva"
                        onAction="#onGuardarPersona" maxWidth="Infinity"
                        style="-fx-background-color: #388E3C; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 10 0 10 0;"/>

                <Button text="✏  Editar Persona"
                        onAction="#onEditarPersona" maxWidth="Infinity"
                        style="-fx-background-color: #E8F5E9; -fx-text-fill: #1B5E20;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 6; -fx-border-color: #C8E6C9;
                               -fx-cursor: hand; -fx-padding: 10 0 10 0;"/>

                <Button text="🗑  Eliminar Persona"
                        onAction="#onEliminarPersona" maxWidth="Infinity"
                        style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;
                               -fx-font-size: 12px; -fx-background-radius: 6;
                               -fx-border-color: #FFCDD2; -fx-cursor: hand;
                               -fx-padding: 9 0 9 0;"/>

                <Button text="🔄  Limpiar"
                        onAction="#limpiar" maxWidth="Infinity"
                        style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;
                               -fx-font-size: 12px; -fx-background-radius: 6;
                               -fx-cursor: hand; -fx-padding: 9 0 9 0;"/>
            </VBox>
        </VBox>

        <!-- ── COLUMNA DERECHA: Tabla ── -->
        <VBox spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                     -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Personas Registradas"
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtBuscar" promptText="🔍  Buscar persona..."
                           prefWidth="230"
                           style="-fx-background-radius: 20; -fx-border-radius: 20;
                                  -fx-border-color: #E0E0E0; -fx-border-width: 1;
                                  -fx-padding: 5 12 5 12;"/>
            </HBox>
            <Separator/>

            <TableView fx:id="tablaPersonas" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId"        text="#"         prefWidth="50"/>
                    <TableColumn fx:id="colNombre"    text="Nombre"    prefWidth="120"/>
                    <TableColumn fx:id="colApellido"  text="Apellido"  prefWidth="120"/>
                    <TableColumn fx:id="colGenero"    text="Género"    prefWidth="80"/>
                    <TableColumn fx:id="colTelefono"  text="Teléfono"  prefWidth="110"/>
                    <TableColumn fx:id="colCorreo"    text="Correo"    prefWidth="160"/>
                    <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="220"/>
                </columns>
                <placeholder>
                    <Label text="No hay personas registradas aún 👥"
                           style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>
        </VBox>

    </HBox>
</VBox>
