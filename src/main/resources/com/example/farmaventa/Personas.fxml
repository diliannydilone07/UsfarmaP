<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" style="-fx-background-color: #F4F6F8;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.farmaventa.PersonaController" maxHeight="Infinity" VBox.vgrow="ALWAYS">

    <!-- ENCABEZADO -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <padding><Insets bottom="18" left="24" right="24" top="18" /></padding>
        <VBox spacing="2">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="Gestión de Personas" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;" text="Registra personas con su dirección completa" />
        </VBox>
    </HBox>

    <HBox minHeight="580" spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

        <!-- COLUMNA IZQUIERDA -->
        <VBox maxWidth="290" minWidth="290" prefWidth="290"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                     -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">

            <ScrollPane fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="12">
                    <padding><Insets bottom="10" left="18" right="18" top="20" /></padding>

                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Registro de Persona" />
                    <Separator opacity="0.16" style="-fx-background-color: #E0E0E0;" />

                    <!-- Selector de rol -->
                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Tipo de Persona *" />
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <RadioButton fx:id="rbCliente" selected="true"
                                         style="-fx-text-fill: #424242; -fx-font-size: 12px;" text="Cliente">
                                <toggleGroup><ToggleGroup fx:id="tgTipo" /></toggleGroup>
                            </RadioButton>
                            <RadioButton fx:id="rbEmpleado"
                                         style="-fx-text-fill: #424242; -fx-font-size: 12px;" text="Empleado"
                                         toggleGroup="$tgTipo" />
                            <RadioButton fx:id="rbProveedor"
                                         style="-fx-text-fill: #424242; -fx-font-size: 12px;" text="Proveedor"
                                         toggleGroup="$tgTipo" />
                        </HBox>
                    </VBox>

                    <!-- ── EMPLEADO (oculto por defecto) ── -->
                    <VBox fx:id="vboxEmpleado" managed="false" spacing="12" visible="false">
                        <Separator style="-fx-background-color: #E0E0E0;" />
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="Datos de Empleado" />
                        <VBox spacing="4">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Cargo" />
                            <ComboBox fx:id="cmbCargo" maxWidth="Infinity" promptText="Seleccionar cargo..."
                                      style="-fx-background-radius: 6;" />
                        </VBox>
                        <VBox spacing="4">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Fecha de Contratación" />
                            <DatePicker fx:id="dpHorario" maxWidth="Infinity" style="-fx-background-radius: 6;" />
                        </VBox>
                    </VBox>

                    <!-- ── CLIENTE (visible por defecto) ── -->
                    <VBox fx:id="vboxCliente" spacing="12">
                        <Separator opacity="0.16" style="-fx-background-color: #E0E0E0;" />
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="Seguro Médico (opcional)" />
                        <VBox spacing="4">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Aseguradora" />
                            <ComboBox fx:id="cmbAseguradora" maxWidth="Infinity" promptText="Seleccionar aseguradora..."
                                      style="-fx-background-radius: 6;" />
                        </VBox>
                        <VBox spacing="4">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Seguro" />
                            <ComboBox fx:id="cmbSeguro" maxWidth="Infinity" promptText="Seleccionar seguro..."
                                      style="-fx-background-radius: 6;" />
                        </VBox>
                    </VBox>

                    <!-- ── PROVEEDOR (oculto por defecto) ── -->
                    <VBox fx:id="vboxProveedor" managed="false" spacing="12" visible="false">
                        <Separator style="-fx-background-color: #E0E0E0;" />
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="Datos de Proveedor" />
                        <VBox spacing="4">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Nombre Empresa *" />
                            <TextField fx:id="txtNombreEmpresa" promptText="Ej. Farmacéutica Del Norte"
                                       style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                        </VBox>
                        <VBox spacing="4">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Categoría de Proveedor *" />
                            <ComboBox fx:id="cmbCategoriaProveedor" maxWidth="Infinity"
                                      promptText="Seleccionar categoría..."
                                      style="-fx-background-radius: 6;" />
                        </VBox>
                        <VBox spacing="4">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Correo Empresa" />
                            <TextField fx:id="txtCorreoEmpresa" promptText="empresa@ejemplo.com"
                                       style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                        </VBox>
                        <VBox spacing="4">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Teléfono Empresa" />
                            <TextField fx:id="txtTelefonoEmpresa" promptText="809-000-0000"
                                       style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                        </VBox>
                        <VBox spacing="4">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="RNC / DNI" />
                            <TextField fx:id="txtDniProveedor" promptText="Ej. 1-23-45678-9"
                                       style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                        </VBox>
                    </VBox>

                    <Separator opacity="0.16" style="-fx-background-color: #E0E0E0;" />

                    <!-- Datos personales -->
                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Nombre *" />
                        <TextField fx:id="txtNombre" promptText="Nombre"
                                   style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Apellido *" />
                        <TextField fx:id="txtApellido" promptText="Apellido"
                                   style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Género *" />
                        <ComboBox fx:id="cmbGenero" maxWidth="Infinity" promptText="Seleccionar..."
                                  style="-fx-background-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Teléfono" />
                        <TextField fx:id="txtTelefono" promptText="809-000-0000"
                                   style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Correo electrónico" />
                        <TextField fx:id="txtCorreo" promptText="correo@ejemplo.com"
                                   style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <!-- DIRECCIÓN -->
                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Dirección" />
                    <Separator opacity="0.16" style="-fx-background-color: #E0E0E0;" />

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Región" />
                        <ComboBox fx:id="cmbRegion" maxWidth="Infinity" promptText="Seleccionar región..."
                                  style="-fx-background-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Provincia" />
                        <ComboBox fx:id="cmbProvincia" maxWidth="Infinity" promptText="Seleccionar provincia..."
                                  style="-fx-background-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Municipio" />
                        <ComboBox fx:id="cmbMunicipio" maxWidth="Infinity" promptText="Seleccionar municipio..."
                                  style="-fx-background-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Sector" />
                        <TextField fx:id="txtSector" promptText="Ej. Los Jardines"
                                   style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Calle" />
                        <TextField fx:id="txtCalle" promptText="Ej. Calle Principal #5"
                                   style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                    <VBox spacing="4">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Descripción" />
                        <TextField fx:id="txtDescripcionDireccion" promptText="Ej. Casa #5, frente al parque"
                                   style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- Botones fijos abajo -->
            <VBox spacing="8">
                <padding><Insets bottom="18" left="18" right="18" top="10" /></padding>
                <Separator style="-fx-background-color: #E0E0E0;" />
                <HBox spacing="8">
                    <Button maxWidth="Infinity" fx:id="btnGuardarPersona" onAction="#onGuardarPersona"
                            style="-fx-background-color: #388E3C; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 6;
                                   -fx-cursor: hand; -fx-padding: 10 0 10 0;"
                            text="💾  Guardar Persona" HBox.hgrow="ALWAYS" />
                    <Button onAction="#limpiar"
                            style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;
                                   -fx-background-radius: 6; -fx-cursor: hand;
                                   -fx-padding: 10 14 10 14;" text="✖" />
                </HBox>
            </VBox>
        </VBox>

        <!-- COLUMNA DERECHA: tabla -->
        <VBox spacing="12"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                     -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;"
              HBox.hgrow="ALWAYS">
            <padding><Insets bottom="20" left="18" right="18" top="20" /></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Personas Registradas" />
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtBuscar" prefWidth="220" promptText="🔍 Buscar persona..."
                           style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
            </HBox>
            <Separator style="-fx-background-color: #E0E0E0;" />

            <TableView fx:id="tablaPersonas" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"        prefWidth="50"  text="#" />
                    <TableColumn fx:id="colNombre"    prefWidth="120" text="Nombre" />
                    <TableColumn fx:id="colApellido"  prefWidth="120" text="Apellido" />
                    <TableColumn fx:id="colGenero"    prefWidth="80"  text="Género" />
                    <TableColumn fx:id="colTelefono"  prefWidth="110" text="Teléfono" />
                    <TableColumn fx:id="colCorreo"    prefWidth="160" text="Correo" />
                    <TableColumn fx:id="colDireccion" prefWidth="220" text="Dirección" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;"
                           text="No hay personas registradas aún 👥" />
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button fx:id="btnEditarPersona" onAction="#onEditarPersona"
                        style="-fx-background-color: #E3F2FD; -fx-text-fill: #1565C0;
                               -fx-font-weight: bold; -fx-font-size: 12px;
                               -fx-background-radius: 6; -fx-border-color: #BBDEFB;
                               -fx-cursor: hand; -fx-padding: 8 14 8 14;" text="✏  Editar Persona" />
                <Button fx:id="btnEliminarPersona" onAction="#onEliminarPersona"
                        style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;
                               -fx-border-color: #FFCDD2; -fx-font-size: 12px;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 8 14 8 14;" text="🗑  Eliminar Persona" />
            </HBox>
        </VBox>

    </HBox>
</VBox>
