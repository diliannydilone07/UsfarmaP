<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" style="-fx-background-color: #F4F6F8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.farmaventa.ReclamacionCompraController">

    <!-- ══════  ENCABEZADO  ══════ -->
    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-background-color: #FFFFFF;                  -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <padding><Insets bottom="16" left="24" right="24" top="16" /></padding>
        <VBox spacing="2">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="Reclamaciones de Compra" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;" text="Registra, revisa y gestiona reclamaciones a proveedores" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblContPendiente" style="-fx-background-color: #FFF8E1; -fx-text-fill: #F57F17;                       -fx-background-radius: 20; -fx-padding: 5 14 5 14;                       -fx-font-size: 12px; -fx-font-weight: bold;" text="⏳  0  Pendientes" />
        <Label fx:id="lblContRevision" style="-fx-background-color: #E3F2FD; -fx-text-fill: #1565C0;                       -fx-background-radius: 20; -fx-padding: 5 14 5 14;                       -fx-font-size: 12px; -fx-font-weight: bold;" text="🔍  0  En Revisión" />
        <Label fx:id="lblContAprobada" style="-fx-background-color: #E8F5E9; -fx-text-fill: #2E7D32;                       -fx-background-radius: 20; -fx-padding: 5 14 5 14;                       -fx-font-size: 12px; -fx-font-weight: bold;" text="✔  0  Aprobadas" />
        <Label fx:id="lblContRechazada" style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;                       -fx-background-radius: 20; -fx-padding: 5 14 5 14;                       -fx-font-size: 12px; -fx-font-weight: bold;" text="✖  0  Rechazadas" />
    </HBox>

    <!-- ══════  FORMULARIO  ══════ -->
    <VBox style="-fx-background-color: #FFFFFF;                  -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <padding><Insets bottom="20" left="24" right="24" top="20" /></padding>

        <Label style="-fx-font-weight: bold; -fx-font-size: 14px;                       -fx-text-fill: #2E7D32; -fx-padding: 0 0 12 0;" text="Nueva Reclamación de Compra" />

        <HBox spacing="16">
            <!-- ID Reclamación -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Reclamación" />
                <TextField fx:id="txtIdReclamacion" editable="false" promptText="Automático" style="-fx-background-color: #F5F5F5; -fx-background-radius: 6;                                   -fx-border-color: #E0E0E0; -fx-border-radius: 6;                                   -fx-text-fill: #9E9E9E; -fx-pref-height: 34;" />
            </VBox>

            <!-- ID Compra + buscar -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Compra *" />
                <HBox spacing="6">
                    <TextField fx:id="txtIdCompra" promptText="Ej. 10" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0;                                       -fx-border-radius: 6; -fx-pref-height: 34;" HBox.hgrow="ALWAYS" />
                    <Button onAction="#onBuscarCompra" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                    -fx-background-radius: 6; -fx-cursor: hand;                                    -fx-font-size: 12px; -fx-pref-height: 34; -fx-pref-width: 40;" text="🔎" />
                </HBox>
            </VBox>

            <!-- Proveedor (solo lectura) -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Proveedor" />
                <TextField fx:id="txtProveedor" editable="false" promptText="Se llena al buscar la compra" style="-fx-background-color: #F5F5F5; -fx-background-radius: 6;                                   -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-pref-height: 34;" />
            </VBox>

            <!-- Fecha -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Fecha *" />
                <DatePicker fx:id="dpFechaReclamacion" maxWidth="Infinity" style="-fx-background-radius: 6; -fx-pref-height: 34;" />
            </VBox>

            <!-- Estado -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Estado *" />
                <ComboBox fx:id="cmbEstadoActual" maxWidth="Infinity" promptText="Seleccionar..." style="-fx-background-radius: 6; -fx-pref-height: 34;" />
            </VBox>

            <!-- Cantidad -->
            <VBox prefWidth="110" spacing="5">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Cant. Devolver" />
                <TextField fx:id="txtCantidadDevolver" promptText="0" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0;                                   -fx-border-radius: 6; -fx-pref-height: 34;" />
            </VBox>
        </HBox>

        <!-- Segunda fila: ID Producto + Nombre Producto -->
        <HBox spacing="16" style="-fx-padding: 10 0 0 0;">
            <VBox prefWidth="160" spacing="5">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="ID Producto *" />
                <HBox spacing="6">
                    <TextField fx:id="txtIdProducto" prefWidth="110.0" promptText="Ej. 12" style="-fx-background-radius: 6; -fx-border-color: #E0E0E0;                                       -fx-border-radius: 6; -fx-pref-height: 34;" HBox.hgrow="ALWAYS" />
               <Button layoutX="147.0" layoutY="10.0" onAction="#onBuscarProducto" prefWidth="63.0" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                    -fx-background-radius: 6; -fx-cursor: hand;                                    -fx-font-size: 12px; -fx-pref-height: 34; -fx-pref-width: 40;" text="🔎" />
                </HBox>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Producto" />
                <TextField fx:id="txtNombreProducto" editable="false" promptText="Se llena al buscar" style="-fx-background-color: #F5F5F5; -fx-background-radius: 6;                                   -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-pref-height: 34;" />
            </VBox>
        </HBox>

        <!-- Tercera fila: Descripción + Botones -->
        <HBox spacing="16" style="-fx-padding: 14 0 0 0;">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #757575;" text="Descripción / Motivo *" />
                <TextField fx:id="txtDescripcion" promptText="Describe el motivo de la reclamación..." style="-fx-background-radius: 6; -fx-border-color: #E0E0E0;                                   -fx-border-radius: 6; -fx-pref-height: 34;" />
            </VBox>
            <HBox alignment="BOTTOM_RIGHT" spacing="10">
                <Button onAction="#onRegistrarReclamacion" style="-fx-background-color: #388E3C; -fx-text-fill: white;                                -fx-font-weight: bold; -fx-font-size: 13px;                                -fx-background-radius: 6; -fx-cursor: hand;                                -fx-pref-height: 34; -fx-padding: 0 20 0 20;" text="📋  Registrar" />
                <Button onAction="#onLimpiarFormulario" style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;                                -fx-background-radius: 6; -fx-cursor: hand;                                -fx-pref-height: 34; -fx-padding: 0 16 0 16;" text="✖  Limpiar" />
            </HBox>
        </HBox>
    </VBox>

    <!-- ══════  TABLA + HISTORIAL  ══════ -->
    <HBox minHeight="400" spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="20" left="20" right="20" top="18" /></padding>

        <!-- ── Tabla de reclamaciones ── -->
        <VBox spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                      -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);                      -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
            <padding><Insets bottom="18" left="18" right="18" top="18" /></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Listado de Reclamaciones" />
                <Region HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="cmbFiltroEstado" prefWidth="170" promptText="Todos los estados" style="-fx-background-radius: 6;" />
                <TextField fx:id="txtBusqueda" prefWidth="220" promptText="🔍 Buscar por ID, proveedor..." style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" />
            </HBox>
            <Separator />

            <TableView fx:id="tablaReclamaciones" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="55" text="ID" />
                    <TableColumn fx:id="colCompra" prefWidth="80" text="Compra" />
                    <TableColumn fx:id="colProveedor" prefWidth="160" text="Proveedor" />
                    <TableColumn fx:id="colFecha" prefWidth="100" text="Fecha" />
                    <TableColumn fx:id="colEstado" prefWidth="130" text="Estado" />
                    <TableColumn fx:id="colCantidad" prefWidth="90" text="Cant. Dev." />
                    <TableColumn fx:id="colDescripcion" prefWidth="200" text="Descripción" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 13px;" text="No hay reclamaciones de compra registradas" />
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#onVerHistorial" style="-fx-background-color: #E3F2FD; -fx-text-fill: #1565C0;                                -fx-font-size: 12px; -fx-background-radius: 6;                                -fx-cursor: hand; -fx-padding: 8 16 8 16;" text="🔍  Ver Historial" />
                <Button onAction="#onAprobar" style="-fx-background-color: #E8F5E9; -fx-text-fill: #2E7D32;                                -fx-font-weight: bold; -fx-font-size: 12px;                                -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16 8 16;" text="✔  Aprobar" />
                <Button onAction="#onRechazar" style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828;                                -fx-border-color: #FFCDD2; -fx-font-size: 12px;                                -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16 8 16;" text="✖  Rechazar" />
                <Button onAction="#onEliminar" style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575;                                -fx-font-size: 12px; -fx-background-radius: 6;                                -fx-cursor: hand; -fx-padding: 8 16 8 16;" text="🗑  Eliminar" />
            </HBox>
        </VBox>

        <!-- ── Panel Historial ── -->
        <VBox minWidth="300" prefWidth="320" spacing="12" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                      -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);                      -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1;">
            <padding><Insets bottom="18" left="18" right="18" top="18" /></padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="2">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2E7D32;" text="Historial de Cambios" />
                    <Label style="-fx-font-size: 10px; -fx-text-fill: #BDBDBD;" text="HISTORICO_RECLAMACION_COMPRA" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblHistorialDe" style="-fx-font-size: 11px; -fx-text-fill: #9E9E9E;                               -fx-background-color: #F5F5F5; -fx-background-radius: 12;                               -fx-padding: 3 10 3 10;" text="—" />
            </HBox>
            <Separator />

            <TableView fx:id="tablaHistorico" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colHistId" prefWidth="45" text="ID" />
                    <TableColumn fx:id="colHistFecha" prefWidth="100" text="Fecha" />
                    <TableColumn fx:id="colHistDescripcion" prefWidth="150" text="Detalle" />
                </columns>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label style="-fx-font-size: 28px;" text="📋" />
                        <Label style="-fx-text-fill: #BDBDBD; -fx-font-size: 12px;" text="Selecciona una reclamación" />
                    </VBox>
                </placeholder>
            </TableView>

            <VBox spacing="6" style="-fx-background-color: #F9FBE7; -fx-background-radius: 8;                          -fx-border-color: #F0F4C3; -fx-border-radius: 8; -fx-border-width: 1;">
                <padding><Insets bottom="10" left="12" right="12" top="10" /></padding>
                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #827717;" text="Detalle del cambio" />
                <TextArea fx:id="txtDetalleHistorial" editable="false" prefRowCount="3" promptText="Selecciona un registro..." style="-fx-background-color: transparent; -fx-border-color: transparent;                                  -fx-font-size: 12px;" wrapText="true" />
            </VBox>

            <Separator />
            <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #424242;" text="Añadir nota al historial" />
            <TextArea fx:id="txtNuevaNotaHistorial" prefRowCount="2" promptText="Escribe una nota o cambio de estado..." style="-fx-background-radius: 6; -fx-border-color: #E0E0E0; -fx-border-radius: 6;" wrapText="true" />
            <Button maxWidth="Infinity" onAction="#onAgregarNota" style="-fx-background-color: #E8F5E9; -fx-text-fill: #1B5E20;                            -fx-font-weight: bold; -fx-background-radius: 6;                            -fx-cursor: hand; -fx-padding: 9 0 9 0;" text="➕  Agregar Nota" />
        </VBox>

    </HBox>
</VBox>
