                                <padding><Insets bottom="8" left="10" right="10" top="8"/></padding>
                                <padding><Insets bottom="8" left="10" right="10" top="8"/></padding>
                                <Label style="-fx-font-size: 10px; -fx-text-fill: #757575; -fx-font-weight: bold;"
                                       text="ASEGURADORA"/>
                                <Label fx:id="lblMontoAseguradora"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"
                                       text="RD$ 0.00" wrapText="true"/>
                            </VBox>
                            <VBox spacing="2"
