                            <HBox spacing="8">
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="Monto pagado (RD$)"/>
                                    <TextField fx:id="txtMontoAsegPagado" promptText="0.00"
