                            </VBox>
                        </VBox>


                        <Separator opacity="0.16" style="-fx-background-color: #E8F5E9;"/>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1B5E20;"
