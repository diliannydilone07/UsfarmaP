                                        style="-fx-background-color: #1B5E20; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;
                                               -fx-background-radius: 9; -fx-border-color: #145214; -fx-border-radius: 9; -fx-border-width: 1;
                                               -fx-cursor: hand; -fx-padding: 9 18 9 18;"
                                        text="Registrar Venta" HBox.hgrow="ALWAYS"/>
                                <Button onAction="#onLimpiarSeguro" prefHeight="39.0" prefWidth="100.0"
