                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="Nombre del Producto"/>
                            <TextField fx:id="txtNombreProdSeg" editable="false" promptText="Se llena al buscar"
                                       style="-fx-background-color: #F5F5F5; -fx-background-radius: 7; -fx-border-color: #C8D8C8;
                                              -fx-border-radius: 7; -fx-border-width: 1; -fx-padding: 7; -fx-pref-height: 34;"/>
                        </VBox>
                        <VBox prefWidth="65" spacing="3">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="Cantidad"/>
                            <TextField fx:id="txtCantProdSeg" promptText="1"
                                       style="-fx-background-radius: 7; -fx-border-color: #C8D8C8; -fx-border-radius: 7;
                                              -fx-border-width: 1; -fx-padding: 7; -fx-pref-height: 34;"/>
                        </VBox>
                        <VBox prefWidth="95" spacing="3">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="Precio (RD$)"/>
                            <TextField fx:id="txtPrecioProdSeg" editable="false" promptText="0.00"
                                       style="-fx-background-color: #F1F8E9; -fx-background-radius: 7; -fx-border-color: #C8E6C9;
                                              -fx-border-radius: 7; -fx-border-width: 1; -fx-padding: 7; -fx-pref-height: 34;"/>
                        </VBox>
                        <VBox prefWidth="80" spacing="3">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="Cobertura %"/>
                            <TextField fx:id="txtPctCobertura" promptText="70"
                                       style="-fx-background-color: #F1F8E9; -fx-background-radius: 7; -fx-border-color: #C8E6C9;
                                              -fx-border-radius: 7; -fx-border-width: 1; -fx-padding: 7; -fx-pref-height: 34;"/>
                        </VBox>
                        <VBox alignment="BOTTOM_LEFT" spacing="3">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: transparent;" text="x"/>
                            <Button onAction="#onBuscarProdSeguro"
                                    style="-fx-background-color: #ECEFF1; -fx-text-fill: #455A64; -fx-font-size: 12px; -fx-font-weight: bold;
                                           -fx-background-radius: 7; -fx-border-color: #CFD8DC; -fx-border-radius: 7; -fx-border-width: 1;
                                           -fx-cursor: hand; -fx-pref-height: 34; -fx-pref-width: 80;"
                                    text="Buscar"/>
                        </VBox>
                        <VBox alignment="BOTTOM_LEFT" spacing="3">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: transparent;" text="x"/>
                            <Button onAction="#onAgregarProdSeguro"
                                    style="-fx-background-color: #1B5E20; -fx-text-fill: #FFFFFF; -fx-font-size: 12px; -fx-font-weight: bold;
                                           -fx-background-radius: 7; -fx-border-color: #145214; -fx-border-radius: 7; -fx-border-width: 1;
                                           -fx-cursor: hand; -fx-pref-height: 34; -fx-pref-width: 95;"
                                    text="+ Agregar"/>
                        </VBox>
                    </HBox>

                    <TableView fx:id="tablaSeguro"
                               style="-fx-background-color: transparent; -fx-border-color: #E8F0E8; -fx-border-radius: 8;"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colSegProd"    prefWidth="250" text="Producto"/>
                            <TableColumn fx:id="colSegCant"    prefWidth="60"  text="Cant."/>
                            <TableColumn fx:id="colSegPrecio"  prefWidth="110" text="Precio Unit."/>
                            <TableColumn fx:id="colSegSub"     prefWidth="110" text="Subtotal"/>
                            <TableColumn fx:id="colSegPctCob"  prefWidth="80"  text="Aseg."/>
                            <TableColumn fx:id="colSegPctCli"  prefWidth="80"  text="Cliente"/>
                            <TableColumn fx:id="colSegMtoAseg" prefWidth="120" text="Paga Aseg."/>
                            <TableColumn fx:id="colSegMtoCli"  prefWidth="120" text="Paga Cliente"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <placeholder>
                            <Label style="-fx-text-fill: #90A4AE; -fx-font-size: 13px;"
                                   text="No hay productos asegurados"/>
                        </placeholder>
                    </TableView>

                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button fx:id="btnEditarSeguro" onAction="#onEditarVentaSeguro"
                                style="-fx-background-color: #E3F2FD; -fx-text-fill: #1565C0; -fx-font-size: 12px; -fx-font-weight: bold;
