                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="Monto pagado (RD$)"/>
                                    <TextField fx:id="txtMontoCliPagado" promptText="0.00"
                                               style="-fx-background-radius: 7; -fx-border-color: #C8D8C8; -fx-border-radius: 7;
                                                      -fx-border-width: 1; -fx-padding: 7;"/>
                                </VBox>
                                <VBox spacing="3" prefWidth="130">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #757575;" text="Metodo"/>
                                    <ComboBox fx:id="cmbMetodoPagoCli" maxWidth="Infinity"
                                              promptText="Efectivo..."
                                              style="-fx-background-radius: 7; -fx-border-color: #C8D8C8; -fx-border-radius: 7;"/>
                                </VBox>
                            </HBox>
                            <Label fx:id="lblPendienteCli"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #C62828;"
                                   text="RD$ 0.00" wrapText="true"/>
                        </VBox>

                        <Separator opacity="0.16" style="-fx-background-color: #E8F5E9;"/>


