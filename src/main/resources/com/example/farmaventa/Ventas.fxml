                        <Button fx:id="btnQuitarProdSeguro" onAction="#onQuitarProdSeguro"
                                style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828; -fx-font-size: 12px; -fx-font-weight: bold;
