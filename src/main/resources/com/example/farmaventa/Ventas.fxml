                                               -fx-cursor: hand; -fx-padding: 9 16 9 16;"
                                        text="Limpiar"/>
                            </HBox>

                            <Button fx:id="btnRegistrarPagoSeguro" maxWidth="Infinity"
                                    onAction="#onRegistrarPagoSeguro"
                                    style="-fx-background-color: #E8F5E9; -fx-text-fill: #1B5E20; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 9; -fx-border-color: #C8E6C9; -fx-border-radius: 9; -fx-border-width: 1;
                                            -fx-cursor: hand; -fx-padding: 8 18 8 18;"
                                    text="💳 Registrar Pago sobre Venta Existente"/>
                        </VBox>
