<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.farmaventa.HelloController"
            style="-fx-background-color: #FFFFFF;">
    <top>
        <HBox style="-fx-background-color: #2E7D32;">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Registro de Venta"
                   style="-fx-text-fill: white;
                    -fx-font-size: 18px;-fx-font-weight: bold;" />
        </HBox>
    </top>
    <center>
        <HBox spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <VBox spacing="10" prefWidth="260"
                  style="-fx-background-color: #E8F5E9;
                    -fx-background-radius: 8;">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>

                </padding>



                <Label text="Datos de la Venta"

                       style="-fx-font-weight: bold;

-fx-text-fill: #2E7D32;" />



                <TextField promptText="ID Cliente"/>

                <TextField promptText="ID Empleado"/>



                <ComboBox fx:id="cmbTipoVenta" promptText="Tipo de Venta"/>



                <DatePicker/>

                <TextField promptText="Condición"/>

            </VBox>




            <VBox spacing="10" HBox.hgrow="ALWAYS">



                <Label text="Productos Vendidos"

                       style="-fx-font-weight: bold;

-fx-text-fill: #2E7D32;" />



                <TableView fx:id="tablaVentaProducto" VBox.vgrow="ALWAYS">

                    <columns>

                        <TableColumn text="Producto" prefWidth="200"/>

                        <TableColumn text="Cantidad" prefWidth="100"/>

                        <TableColumn text="Precio Unitario" prefWidth="140"/>

                    </columns>

                </TableView>



                <HBox spacing="20" alignment="CENTER_RIGHT">

                    <VBox alignment="CENTER_RIGHT">

                        <Label text="Monto Total"/>

                        <Label fx:id="lblMontoTotal"

                               style="-fx-font-weight: bold;

-fx-text-fill: #2E7D32;" />

                    </VBox>



                    <VBox alignment="CENTER_RIGHT">

                        <Label text="Monto Pendiente"/>

                        <Label fx:id="lblMontoPendiente"

                               style="-fx-font-weight: bold;

-fx-text-fill: #C62828;" />

                    </VBox>

                </HBox>

            </VBox>




            <VBox spacing="12" prefWidth="180">



                <Button text="Agregar Producto"

                        maxWidth="Infinity"

                        style="-fx-background-color: #2E7D32;

-fx-text-fill: white;" />



                <Button text="Quitar Producto"

                        maxWidth="Infinity"

                        style="-fx-background-color: #A5D6A7;" />



                <Separator/>



                <Button text="Registrar Venta"

                        maxWidth="Infinity"

                        style="-fx-background-color: #388E3C;

-fx-text-fill: white;" />

            </VBox>



        </HBox>

    </center>



</BorderPane>