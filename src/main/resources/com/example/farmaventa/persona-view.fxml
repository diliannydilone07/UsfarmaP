<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.farmaventa.PersonaController">

    <top>
        <HBox style="-fx-background-color: #2E7D32;">
            <padding>
                <Insets bottom="15" left="20" right="20" top="15" />
            </padding>
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Gestión de Personas (Clientes y Empleados)" />
        </HBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <VBox prefWidth="300" spacing="10" style="-fx-background-color: #E8F5E9; -fx-background-radius: 8;">
                <padding>
                    <Insets bottom="15" left="15" right="15" top="15" />
                </padding>

                <Label style="-fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="Registro de Información" />

                <HBox spacing="10">
                    <RadioButton fx:id="rbCliente" selected="true" text="Cliente">
                        <toggleGroup><ToggleGroup fx:id="tgTipo" /></toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="rbEmpleado" text="Empleado" toggleGroup="$tgTipo" />
                </HBox>

                <Separator />

                <TextField fx:id="txtId" promptText="ID Persona (#)" />
                <TextField fx:id="txtNombre" promptText="Nombre (*)" />
                <TextField fx:id="txtApellido" promptText="Apellido (*)" />
                <ComboBox fx:id="cmbGenero" maxWidth="Infinity" promptText="Género" />
                <TextField fx:id="txtTelefono" promptText="Teléfono" />
                <TextField fx:id="txtEmail" promptText="Correo Electrónico" />

                <VBox fx:id="vboxDatosEmpleado" managed="false" spacing="10" visible="false">
                    <Separator />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #2E7D32; -fx-font-weight: bold;" text="Datos de Empleado" />
                    <ComboBox fx:id="cmbCargo" maxWidth="Infinity" promptText="Seleccionar Cargo" />
                    <DatePicker fx:id="dpHorario" maxWidth="Infinity" promptText="Fecha de Contratación" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Button maxWidth="Infinity" style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar Registro" />
            </VBox>

            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="Listado General" />
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="txtBusqueda" prefWidth="200" promptText="🔍 Buscar..." />
                </HBox>

                <TableView fx:id="tablaPersonas" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                        <TableColumn fx:id="colNombre" prefWidth="120" text="Nombre" />
                        <TableColumn fx:id="colTipo" prefWidth="80" text="Tipo" /> <TableColumn fx:id="colCargo" prefWidth="100" text="Cargo" /> <TableColumn fx:id="colTelefono" prefWidth="100" text="Teléfono" />
                        <TableColumn fx:id="colEmail" prefWidth="150" text="Correo" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Button style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828; -fx-border-color: #FFCDD2;" text="Eliminar" />
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
