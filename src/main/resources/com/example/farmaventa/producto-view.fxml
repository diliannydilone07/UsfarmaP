<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #FFFFFF;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://webhook.javafx.com/javafx/17.0.12" fx:controller="com.example.farmaventa.ProductoController">

    <top>
        <HBox style="-fx-background-color: #2E7D32;">
            <padding>
                <Insets bottom="15" left="20" right="20" top="15" />
            </padding>
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Gestión de Inventario (Productos)" />
        </HBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <VBox prefWidth="300" spacing="10" style="-fx-background-color: #E8F5E9; -fx-background-radius: 8;">
                <padding>
                    <Insets bottom="15" left="15" right="15" top="15" />
                </padding>

                <Label style="-fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="Registro de Producto" />
                <Separator />

                <Label text="ID Producto (#)" style="-fx-font-size: 11px;" />
                <TextField fx:id="txtId" promptText="Automático o Manual" />

                <Label text="Nombre del Producto (*)" style="-fx-font-size: 11px;" />
                <TextField fx:id="txtNombre" promptText="Ej. Paracetamol 500mg" />

                <Label text="Categoría (*)" style="-fx-font-size: 11px;" />
                <ComboBox fx:id="cmbCategoria" maxWidth="Infinity" promptText="Seleccionar..." />

                <HBox spacing="10">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Stock Disponible" style="-fx-font-size: 11px;" />
                        <TextField fx:id="txtStockActual" promptText="0" />
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Stock Mínimo" style="-fx-font-size: 11px;" />
                        <TextField fx:id="txtStockMinimo" promptText="5" />
                    </VBox>
                </HBox>

                <Label text="Descuento (%)" style="-fx-font-size: 11px;" />
                <TextField fx:id="txtDescuento" promptText="0.00" />

                <Label text="Ubicación" style="-fx-font-size: 11px;" />
                <TextField fx:id="txtUbicacion" promptText="Pasillo A - Estante 3" />

                <Region VBox.vgrow="ALWAYS" />

                <Button onAction="#onGuardarProductoClick" maxWidth="Infinity" style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar Producto" />
            </VBox>

            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="Inventario General" />
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="txtBusqueda" prefWidth="250" promptText="🔍 Buscar por nombre o ID..." />
                </HBox>

                <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                        <TableColumn fx:id="colNombre" prefWidth="180" text="Nombre" />
                        <TableColumn fx:id="colStock" prefWidth="80" text="Stock" />
                        <TableColumn fx:id="colMinimo" prefWidth="80" text="Min." />
                        <TableColumn fx:id="colUbicacion" prefWidth="120" text="Ubicación" />
                        <TableColumn fx:id="colDescuento" prefWidth="80" text="Desc. %" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Label text="Cant. a vender:" style="-fx-font-size: 12px;"/>
                    <Spinner fx:id="spinCantidad" prefWidth="80" />
                    <Button onAction="#onAñadirClick" style="-fx-background-color: #A5D6A7; -fx-text-fill: #1B5E20; -fx-font-weight: bold;" text="Añadir a Carrito" />
                    <Button onAction="#onCancelarClick" style="-fx-background-color: #FFEBEE; -fx-text-fill: #C62828; -fx-border-color: #FFCDD2;" text="Eliminar Producto" />
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>